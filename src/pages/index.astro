  <!-- ── GHI MAGAZINE / BLOG ──────────────────────────────── -->
  <section class="section bg-[#F8F9F3]">
    <div class="container mx-auto">
      <div class="text-center mb-8">
        <span class="eyebrow" style="color: #1d803f;">Stories from the Field</span>
        <h2>GHI Magazine</h2>
      </div>

      <!-- Featured circular thumbnails -->
      <div class="flex justify-center gap-4 mb-6">
        {(blogPosts.length > 0 ? blogPosts.slice(0, 3) : fallbackBlogPosts.slice(0, 3)).map((post: any) => (
          <div class="w-20 h-20 md:w-24 md:h-24 rounded-full border-3 border-[#2EAB5A] overflow-hidden shadow-sm">
            <img
              src={`${post.imageUrl || post.image}?w=200&auto=format`}
              alt={post.title}
              width="96" height="96" loading="lazy"
              class="w-full h-full object-cover"
            />
          </div>
        ))}
      </div>

      <!-- Tag filter chips -->
      <div class="flex justify-center gap-2 flex-wrap mb-10">
        {['Partners', 'Projects', 'Healthcare', 'Community', 'Education'].map(tag => (
          <span class="inline-block bg-[#1d803f] text-white text-xs font-semibold rounded-full px-4 py-1.5">{tag}</span>
        ))}
      </div>

      {blogPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {blogPosts.map(post => (
            <a
              href={`/blog/${post.slug}`}
              class="group bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col"
            >
              <div class="overflow-hidden">
                {post.imageUrl ? (
                  <img
                    src={`${post.imageUrl}?w=600&auto=format`}
                    alt={post.title}
                    width="600" height="180" loading="lazy"
                    class="w-full h-[180px] object-cover object-bottom transition-transform duration-300 group-hover:scale-105"
                  />
                ) : (
                  <div class="w-full h-[180px] bg-[#1D1C1C] flex items-center justify-center">
                    <span class="text-white/30 text-4xl">🌏</span>
                  </div>
                )}
              </div>
              <div class="p-4 flex flex-col flex-1">
                <p class="text-[16px] font-semibold text-[#1d803f] leading-[1.4] mb-2">{post.title}</p>
                <div class="flex items-center gap-1.5 text-[#1d803f] text-xs mb-3">
                  <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 448 512" fill="currentColor"><path d="M12 192h424c6.6 0 12 5.4 12 12v260c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V204c0-6.6 5.4-12 12-12zm436-44v-36c0-26.5-21.5-48-48-48h-48V12c0-6.6-5.4-12-12-12h-40c-6.6 0-12 5.4-12 12v52H160V12c0-6.6-5.4-12-12-12h-40c-6.6 0-12 5.4-12 12v52H48C21.5 64 0 85.5 0 112v36c0 6.6 5.4 12 12 12h424c6.6 0 12-5.4 12-12z"/></svg>
                  <span>{post.publishDate ? formatDate(post.publishDate) : ''}</span>
                </div>
                <div class="mt-auto inline-flex items-center gap-1.5 text-[#1d803f] text-sm font-semibold group-hover:underline">
                  Read Full Story Here
                  <svg class="w-3.5 h-3.5" viewBox="0 0 448 512" fill="currentColor"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
                </div>
              </div>
            </a>
