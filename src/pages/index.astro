---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity.ts';

// Fetch latest 6 blog posts
let blogPosts: any[] = [];
try {
  blogPosts = await sanityClient.fetch(`
    *[_type == "blogPost"] | order(publishDate desc) [0..5] {
      title,
      "slug": slug.current,
      excerpt,
      publishDate,
      "imageUrl": heroImage.asset->url,
      tags
    }
  `);
} catch (e) {
  // Sanity not yet populated — show empty state
}

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const formatDate = (d: string) => {
  const dt = new Date(d);
  return `${MONTHS[dt.getUTCMonth()]} ${dt.getUTCDate()}, ${dt.getUTCFullYear()}`;
};

const stats = [
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/6dbc6e8cd900153cb00f62123e78bd52ba5b618c-500x500.svg', label: 'Donors', value: '1,029' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/94ffe68e3e0680b0c21f2ee1d46cde5298c0dc6f-500x500.svg', label: 'Collecting', value: '$10,000,000' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/95369fa252d43f495b649bc6582b4c5a8ce26ccf-500x500.svg', label: 'Bibles', value: '50,000' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/53c4d85a2901cef03143a8f1bf4c60181864f567-500x500.svg', label: 'Mission Teams', value: '139' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/da89ea6d23cb8d0a1bc30083985a7126209aa346-500x500.svg', label: 'Volunteers', value: '1,002' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/19173860c060a39b8d1dda6cdcded3b665f03ca1-500x500.svg', label: 'Water Projects', value: '143' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/be24a3c6f9211be8005b8e27c17a62c3004e5d93-500x500.svg', label: 'Orphans Sponsored', value: '599' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/db1bf9a4620f71ed820ed9c918e039d83c7a020f-500x500.svg', label: 'Hygiene kits', value: '100,000' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/9c4e4d08eec924a37808ac240f0ff1c22b4ce219-500x500.svg', label: 'Lives Impacted', value: '59,000,000' },
];

const fallbackBlogPosts = [
  { title: 'Our Partners in India', date: 'March 18, 2025', tag: 'Partners', image: 'https://cdn.sanity.io/images/r33r2z1j/production/c1a49b5d5cd211dcfec6e88222c0674f6d76463c-1640x924.webp' },
  { title: 'Support Key Projects in Manipur', date: 'March 18, 2025', tag: 'Projects', image: 'https://cdn.sanity.io/images/r33r2z1j/production/b3f0daaff6ca7cddeeb3832687184e4f35abf8b0-1640x924.webp' },
  { title: 'Medical Camp Miracles: Healing Bodies and Souls', date: 'March 18, 2025', tag: 'Healthcare', image: 'https://cdn.sanity.io/images/r33r2z1j/production/a7047e93eb1370b0e8d473b2057cbd817a8f0755-1640x924.webp' },
  { title: "Hope for India's Special Needs Community", date: 'March 4, 2025', tag: 'Community', image: 'https://cdn.sanity.io/images/r33r2z1j/production/8e7bcac0ab2840741a8ac4f53cb2ce6111c7f613-1640x924.webp' },
  { title: 'Empowering the Deaf Community in Nagaland', date: 'March 4, 2025', tag: 'Community', image: 'https://cdn.sanity.io/images/r33r2z1j/production/06fe4afbcd6d31de5d4dc3ba0bb0cdd0a9e8cccb-1640x924.webp' },
  { title: "Elim School: Supporting Pastor Mayon's Mission", date: 'March 4, 2025', tag: 'Education', image: 'https://cdn.sanity.io/images/r33r2z1j/production/313486fedbeda5e753f0216704b9454e389d893b-1640x924.webp' },
];
---

<Layout
  title="Global Hope India — Sharing Jesus by Sending People, Funding, and Resources"
  description="Global Hope India engages the church worldwide to empower the church in India with needed resources — to make Christ known and extend the Kingdom of God."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "NGO",
      "name": "Global Hope India",
      "url": "https://globalhopeindia.org",
      "description": "Sharing Jesus by Sending People, Funding, and Resources to India",
      "address": { "@type": "PostalAddress", "streetAddress": "PO Box 3251", "addressLocality": "Cary", "addressRegion": "NC", "postalCode": "27519", "addressCountry": "US" },
      "telephone": "919-438-2444",
      "email": "info@globalhopeindia.org",
      "sameAs": ["https://www.facebook.com/GlobalHopeIndia","https://www.youtube.com/@GlobalHopeIndia"]
    })}></script>
  </Fragment>

  <!-- ── HERO (Video Background + Flip Text) ────────────── -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <div class="absolute inset-0 bg-[#1D1C1C]"></div>
    <video
      autoplay
      muted
      loop
      playsinline
      poster="https://cdn.sanity.io/images/r33r2z1j/production/4e4c6eb1e1028931e4e6b32315fe6aa1b2d20e86-500x500.webp"
      class="absolute inset-0 w-full h-full object-cover"
    >
      <source src="https://globalhopeindia.org/wp-content/uploads/2023/12/GHI-Site-Video-v3.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative z-10 container mx-auto px-6">
      <div class="hero-flip-container" style="perspective: 600px;">
        <h1 class="hero-flip-text" style="font-size: clamp(3rem, 8vw, 6rem); font-weight: 700; line-height: 1.1;">
          <!-- Phase A: "Jesus for India" -->
          <span class="flip-phrase flip-phrase-a active">
            <span class="txt-jesus">Jesus</span>
            <span class="txt-for">for</span>
            <span class="txt-india">India</span>
          </span>
          <!-- Phase B: "India for Jesus" -->
          <span class="flip-phrase flip-phrase-b">
            <span class="txt-india">India</span>
            <span class="txt-for">for</span>
            <span class="txt-jesus">Jesus</span>
          </span>
        </h1>
      </div>
    </div>
  </section>

  <style>
    .hero-flip-text {
      position: relative;
      display: block;
    }
    .flip-phrase {
      display: inline-flex;
      gap: 0.25em;
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%) rotateX(90deg);
      opacity: 0;
      transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease;
      backface-visibility: hidden;
      white-space: nowrap;
    }
    .flip-phrase.active {
      transform: translate(-50%, -50%) rotateX(0deg);
      opacity: 1;
    }
    .flip-phrase.exit {
      transform: translate(-50%, -50%) rotateX(-90deg);
      opacity: 0;
    }
    /* Reserve vertical space for the text */
    .hero-flip-text::before {
      content: '\00a0';
      display: block;
      visibility: hidden;
      font-size: inherit;
      line-height: 1.1;
    }
    .txt-india { color: #2EAB5A; }
    .txt-jesus { color: #FF4081; }
    .txt-for   { color: #ffffff; }
  </style>

  <script>
    const phrases = document.querySelectorAll('.flip-phrase');
    let current = 0;
    function flipHeroText() {
      const prev = current;
      current = (current + 1) % phrases.length;
      phrases[prev].classList.remove('active');
      phrases[prev].classList.add('exit');
      phrases[current].classList.add('active');
      phrases[current].classList.remove('exit');
      setTimeout(flipHeroText, 3000);
    }
    setTimeout(flipHeroText, 3000);
  </script>

  <!-- ── TAGLINE ─────────────────────────────────────────── -->
  <section class="bg-white py-12 lg:py-16 px-6">
    <div class="container mx-auto text-center">
      <h2 class="text-[#1D1C1C] font-bold mb-4">Sharing Jesus by Sending People, Funding, and Resources</h2>
      <p class="text-[#666] text-lg max-w-3xl mx-auto leading-relaxed">
        Global Hope India engages the church worldwide in order to empower the church in India with needed resources — to make Christ known and extend the Kingdom of God in India.
      </p>
    </div>
  </section>

  <!-- ── 25 YEARS (green box) ────────────────────────────── -->
  <section class="bg-[#2EAB5A] py-12 lg:py-16 px-6">
    <div class="container mx-auto">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="text-center md:text-left">
          <h2 class="text-white font-bold">Celebrating Over <span class="text-[#FEC415]">25 Years</span> in India</h2>
        </div>
        <div class="shrink-0">
          <img
            src="https://cdn.sanity.io/images/r33r2z1j/production/4e4c6eb1e1028931e4e6b32315fe6aa1b2d20e86-500x500.webp"
            alt="Celebrating 25 Years in India"
            width="200"
            height="200"
            class="w-48 h-48 md:w-52 md:h-52"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ── IMPACT STATS (3x3 grid) ─────────────────────────── -->
  <section class="section bg-white">
    <div class="container mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
        {stats.map(stat => (
          <div class="flex items-center gap-4">
            <img src={stat.icon} alt={stat.label} class="w-16 h-16 shrink-0" />
            <div>
              <div class="text-2xl md:text-3xl font-bold text-[#1D1C1C] leading-tight">{stat.value}</div>
              <div class="text-[#666] text-sm font-medium">{stat.label}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── INDIA MAP (full-width visual break) ────────────── -->
  <section class="relative h-[40vh] lg:h-[50vh] flex items-center justify-center overflow-hidden bg-[#1D1C1C]">
    <div class="absolute inset-0 flex items-center justify-center text-[12rem] md:text-[16rem] opacity-10 select-none">🇮🇳</div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#1D1C1C]/60"></div>
    <div class="relative z-10 text-center">
      <span class="inline-block bg-[#2EAB5A] text-white font-bold text-2xl md:text-4xl px-8 py-3 rounded-sm">Impacting India</span>
      <p class="text-white/70 mt-4 text-lg">1.4 billion people. One mission.</p>
    </div>
  </section>

  <!-- ── GHI MAGAZINE / BLOG ──────────────────────────────── -->
  <section class="section bg-[#f5f5f5]">
    <div class="container mx-auto">
      <div class="text-center mb-12">
        <span class="eyebrow">Stories from the Field</span>
        <h2>GHI Magazine</h2>
      </div>

      {blogPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {blogPosts.map(post => (
            <a
              href={`/blog/${post.slug}`}
              class="blog-card bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow group"
            >
              <div class="h-52 overflow-hidden bg-[#1D1C1C]">
                {post.imageUrl ? (
                  <img
                    src={`${post.imageUrl}?w=600&auto=format`}
                    alt={post.title}
                    class="blog-card-img w-full h-full object-cover"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <span class="text-white/30 text-4xl">🌏</span>
                  </div>
                )}
              </div>
              <div class="p-6">
                <h3 class="font-bold text-lg leading-snug mb-2 group-hover:text-[#2EAB5A] transition-colors">{post.title}</h3>
                <div class="text-sm text-[#999] mb-3">{post.publishDate ? formatDate(post.publishDate) : ''}</div>
                <span class="text-[#2EAB5A] font-semibold text-sm group-hover:underline">Read Full Story Here</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <!-- Fallback: static blog posts before Sanity is populated -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {fallbackBlogPosts.map(post => (
            <div class="blog-card bg-white rounded-2xl overflow-hidden shadow-sm">
              <div class="h-52 overflow-hidden">
                <img src={post.image} alt={post.title} class="w-full h-full object-cover" />
              </div>
              <div class="p-6">
                <h3 class="font-bold text-lg leading-snug mb-2">{post.title}</h3>
                <div class="text-sm text-[#999] mb-3">{post.date}</div>
                <span class="text-[#2EAB5A] font-semibold text-sm">Read Full Story Here</span>
              </div>
            </div>
          ))}
        </div>
      )}

      <div class="text-center mt-12">
        <a href="/blog" class="btn" style="background-color: #1D1C1C; color: #fff; border-color: #1D1C1C;">See more blogs</a>
      </div>
    </div>
  </section>

</Layout>
