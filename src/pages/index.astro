---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity.ts';

// Fetch impact stats from Sanity
let stats: any[] = [];
try {
  stats = await sanityClient.fetch(`
    *[_type == "impactStat"] | order(order asc) {
      label, value, "icon": icon
    }
  `);
} catch (e) { /* fallback below */ }

// Fallback stats (hardcoded)
const fallbackStats = [
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/6dbc6e8cd900153cb00f62123e78bd52ba5b618c-500x500.svg', label: 'Donors', value: '1,029' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/94ffe68e3e0680b0c21f2ee1d46cde5298c0dc6f-500x500.svg', label: 'Collecting', value: '$10,000,000' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/95369fa252d43f495b649bc6582b4c5a8ce26ccf-500x500.svg', label: 'Bibles', value: '50,000' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/53c4d85a2901cef03143a8f1bf4c60181864f567-500x500.svg', label: 'Mission Teams', value: '139' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/da89ea6d23cb8d0a1bc30083985a7126209aa346-500x500.svg', label: 'Volunteers', value: '1,002' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/19173860c060a39b8d1dda6cdcded3b665f03ca1-500x500.svg', label: 'Water Projects', value: '143' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/be24a3c6f9211be8005b8e27c17a62c3004e5d93-500x500.svg', label: 'Orphans Sponsored', value: '599' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/db1bf9a4620f71ed820ed9c918e039d83c7a020f-500x500.svg', label: 'Hygiene kits', value: '100,000' },
  { icon: 'https://cdn.sanity.io/images/r33r2z1j/production/9c4e4d08eec924a37808ac240f0ff1c22b4ce219-500x500.svg', label: 'Lives Impacted', value: '59,000,000' },
];
if (stats.length === 0) {
  stats = fallbackStats;
} else {
  // Fill in missing icons from fallback data
  const fallbackByLabel = Object.fromEntries(fallbackStats.map(s => [s.label, s]));
  stats = stats.map(s => ({
    ...s,
    icon: s.icon || fallbackByLabel[s.label]?.icon || '',
  }));
}

// Fetch latest 6 blog posts
let blogPosts: any[] = [];
try {
  blogPosts = await sanityClient.fetch(`
    *[_type == "blogPost"] | order(publishDate desc) [0..5] {
      title,
      "slug": slug.current,
      excerpt,
      publishDate,
      "imageUrl": coalesce(heroImage.asset->url, externalImageUrl),
      tags
    }
  `);
} catch (e) {
  // Sanity not yet populated — show empty state
}

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const formatDate = (d: string) => {
  const dt = new Date(d);
  return `${MONTHS[dt.getUTCMonth()]} ${dt.getUTCDate()}, ${dt.getUTCFullYear()}`;
};

const fallbackBlogPosts = [
  { title: 'Our Partners in India', slug: 'our-partners-in-india', date: 'March 18, 2025', tag: 'Partners', excerpt: 'Global Hope India partners with local churches and ministries across India to bring the gospel, resources, and sustainable development to communities in need.', image: 'https://cdn.sanity.io/images/r33r2z1j/production/c1a49b5d5cd211dcfec6e88222c0674f6d76463c-1640x924.webp' },
  { title: 'Support Key Projects in Manipur', slug: 'support-key-projects-in-manipur', date: 'March 18, 2025', tag: 'Projects', excerpt: 'The state of Manipur faces unique challenges. Discover how GHI is supporting critical projects that bring hope and transformation to this region.', image: 'https://cdn.sanity.io/images/r33r2z1j/production/b3f0daaff6ca7cddeeb3832687184e4f35abf8b0-1640x924.webp' },
  { title: 'Medical Camp Miracles: Healing Bodies and Souls', slug: 'medical-camp-miracles-healing-bodies-and-souls', date: 'March 18, 2025', tag: 'Healthcare', excerpt: 'Our medical camps provide free healthcare to underserved communities while sharing the love of Christ through compassionate service.', image: 'https://cdn.sanity.io/images/r33r2z1j/production/a7047e93eb1370b0e8d473b2057cbd817a8f0755-1640x924.webp' },
  { title: "Hope for India's Special Needs Community: The Mission of Raja's Home", slug: 'hope-for-indias-special-needs', date: 'March 4, 2025', tag: 'Community', excerpt: "Raja's Home provides a safe haven for India's special needs community, offering care, education, and the transformative love of Jesus Christ.", image: 'https://cdn.sanity.io/images/r33r2z1j/production/8e7bcac0ab2840741a8ac4f53cb2ce6111c7f613-1640x924.webp' },
  { title: 'Empowering the Deaf Community: The Mission of DBM in Nagaland, India', slug: 'empowering-the-deaf-community-the-mission-of-dbm-in-nagaland-india', date: 'March 4, 2025', tag: 'Community', excerpt: 'Deaf Bible Ministries in Nagaland is transforming lives by making Scripture accessible and empowering the deaf community through education and faith.', image: 'https://cdn.sanity.io/images/r33r2z1j/production/06fe4afbcd6d31de5d4dc3ba0bb0cdd0a9e8cccb-1640x924.webp' },
  { title: "Elim School: Supporting Pastor Mayon's Mission in Manipur", slug: 'elim-school-supporting-pastor-mayons-mission-in-manipur', date: 'March 4, 2025', tag: 'Education', excerpt: "Pastor Mayon's Elim School provides quality education and spiritual growth to children in Manipur, shaping the next generation of leaders for India.", image: 'https://cdn.sanity.io/images/r33r2z1j/production/313486fedbeda5e753f0216704b9454e389d893b-1640x924.webp' },
];
---

<Layout
  title="Donate to India Missions — Bibles & Church Planting | GHI"
  description="Give to God's work in India. Fund Bible distribution, support missionaries, sponsor orphans, and advance the gospel among 1 billion unreached Indians."
  keywords="giving to God's work in India, empowering God's work in India, building God's kingdom in India, Bibles for India, advancing the gospel in India, building orphanages in India, transforming lives in India, donate to India missions, support Christian missionaries India, fund Bible distribution India, sponsor child India Christian, give to church planting India, support orphans in India, short term mission trip India, pray for India unreached people, 1 billion Indians without Bible, unreached people India, church planting movement India"
>
  <Fragment slot="head">
    <!-- Preconnect to Sanity CDN (LCP badge origin) -->
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <!-- Preload LCP hero poster (responsive; mobile→640w, tablet→960w, desktop→1200w at DPR1) -->
    <link
      rel="preload"
      as="image"
      imagesrcset="https://assets.spiritmediapublishing.com/images/ghi-hero-poster-mobile.webp 640w, https://assets.spiritmediapublishing.com/images/ghi-hero-poster-tablet.webp 960w, https://assets.spiritmediapublishing.com/images/ghi-hero-poster-desktop.webp 1200w"
      imagesizes="(max-width:640px) 320px, (max-width:1023px) 480px, 1200px"
      fetchpriority="high"
    />
    <!-- Preload the 25-years LCP badge (Lighthouse picks it on mobile above-fold) -->
    <link
      rel="preload"
      as="image"
      imagesrcset="https://cdn.sanity.io/images/r33r2z1j/production/4e4c6eb1e1028931e4e6b32315fe6aa1b2d20e86-500x500.webp?w=208&fm=webp&q=85 1x, https://cdn.sanity.io/images/r33r2z1j/production/4e4c6eb1e1028931e4e6b32315fe6aa1b2d20e86-500x500.webp?w=416&fm=webp&q=85 2x"
      fetchpriority="high"
    />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "NGO",
      "name": "Global Hope India",
      "url": "https://globalhopeindia.org",
      "description": "Global Hope India empowers God's work in India by sending mission teams, funding Bible distribution, supporting church planting, and transforming lives among unreached people in India for over 25 years.",
      "address": { "@type": "PostalAddress", "streetAddress": "PO Box 3251", "addressLocality": "Cary", "addressRegion": "NC", "postalCode": "27519", "addressCountry": "US" },
      "telephone": "919-438-2444",
      "email": "info@globalhopeindia.org",
      "sameAs": ["https://www.facebook.com/GlobalHopeIndia","https://www.youtube.com/@GlobalHopeIndia"]
    })}></script>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How does my donation help India?",
          "acceptedAnswer": { "@type": "Answer", "text": "Your donation to Global Hope India funds Bible distribution, supports indigenous church planters, provides orphan care, funds clean water projects, and sends short term mission teams to India. Over 85% of every dollar given directly benefits programs in the USA and India." }
        },
        {
          "@type": "Question",
          "name": "Is Global Hope India a legitimate charity?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Global Hope India is a federally recognized 501(c)(3) nonprofit organization based in Raleigh, North Carolina. We hold a GuideStar Platinum Seal, a Charity Navigator 100 rating, and are accredited by the Better Business Bureau. All gifts are tax-deductible." }
        },
        {
          "@type": "Question",
          "name": "How much of my donation goes to programs?",
          "acceptedAnswer": { "@type": "Answer", "text": "Over 85% of every dollar given to Global Hope India directly benefits our programs in India and the USA, including Bible distribution, church planting, orphan care, and community development." }
        }
      ]
    })}></script>
  </Fragment>

  <!-- ── HERO (Video Background + Flip Text) ────────────── -->
  <section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden">
    <img
      id="hero-poster"
      src="https://assets.spiritmediapublishing.com/images/ghi-hero-poster-desktop.webp"
      srcset="https://assets.spiritmediapublishing.com/images/ghi-hero-poster-mobile.webp 640w, https://assets.spiritmediapublishing.com/images/ghi-hero-poster-tablet.webp 960w, https://assets.spiritmediapublishing.com/images/ghi-hero-poster-desktop.webp 1200w"
      sizes="(max-width:640px) 320px, (max-width:1023px) 480px, 1200px"
      alt="Aerial view of India"
      width="1200"
      height="675"
      fetchpriority="high"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <video
      id="hero-video"
      muted
      loop
      playsinline
      preload="none"
      class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000"
    >
      <source src="https://assets.spiritmediapublishing.com/video/indian-culture-global-hope-india.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="relative z-10 container mx-auto px-6 flex items-center justify-center min-h-screen">
      <div class="hero-flip-container">
        <h1 class="hero-flip-text">
          <span class="flip-word flip-word-left active-word" id="word-left">Jesus</span>
          <span class="txt-for">for</span>
          <span class="flip-word flip-word-right active-word" id="word-right">India</span>
        </h1>
      </div>
    </div>
  </section>

  <!-- ── TAGLINE ─────────────────────────────────────────── -->
  <section class="relative bg-[#F8F5EF] overflow-hidden -mt-40 md:-mt-32 lg:-mt-36 z-10">
    <div class="relative z-10 text-center pt-10 lg:pt-14 pb-6 px-8 lg:px-16">
      <h2 class="text-[#1D1C1C] font-bold mb-0 max-w-5xl mx-auto" style="font-size: clamp(1.25rem, 2.5vw, 2rem); line-height: 1.3;">Empowering God's Work in India — Sending People, Funding, and Bibles</h2>
    </div>
    <!-- Pink banner with mission text -->
    <div class="relative z-10 bg-[#F8C8DC] py-5 px-6">
      <p class="text-[#1D1C1C] text-sm md:text-base leading-relaxed text-center max-w-4xl mx-auto mb-0">
        Global Hope India engages the church worldwide to empower the church in India — advancing the gospel, funding Bible distribution, and building God's kingdom among unreached people in India
      </p>
    </div>
  </section>

  <!-- ── CREAM GAP + GREEN BOX WRAPPER ───────────────────── -->
  <section class="tagline-section relative bg-[#F8F5EF] overflow-hidden z-10">
    <!-- Decorative dashed diagonal lines — both sides -->
    <div class="tagline-dashed-line tagline-dashed-top-left"></div>
    <div class="tagline-dashed-line tagline-dashed-bottom-left"></div>
    <div class="tagline-dashed-line tagline-dashed-top-right"></div>
    <div class="tagline-dashed-line tagline-dashed-bottom-right"></div>
    <!-- Cream gap -->
    <div class="h-10 lg:h-14"></div>
    <!-- Green 25 Years box -->
    <div class="relative z-10 mx-4 lg:mx-auto lg:max-w-6xl bg-[#2EAB5A] py-10 lg:py-12 px-6 rounded-[10px] shadow-[0px_0px_10px_0px_rgba(0,0,0,0.5)]">
      <div class="container mx-auto">
        <div class="flex flex-col md:flex-row items-center justify-between gap-8">
          <div class="text-center md:text-left">
            <h2 class="text-white font-bold">Celebrating Over <span class="text-[#1D1C1C]">25 Years</span> in India</h2>
          </div>
          <div class="shrink-0">
            <img
              src="https://cdn.sanity.io/images/r33r2z1j/production/4e4c6eb1e1028931e4e6b32315fe6aa1b2d20e86-500x500.webp?w=208&fm=webp&q=85"
              srcset="https://cdn.sanity.io/images/r33r2z1j/production/4e4c6eb1e1028931e4e6b32315fe6aa1b2d20e86-500x500.webp?w=208&fm=webp&q=85 1x, https://cdn.sanity.io/images/r33r2z1j/production/4e4c6eb1e1028931e4e6b32315fe6aa1b2d20e86-500x500.webp?w=416&fm=webp&q=85 2x"
              alt="Celebrating over 25 years of advancing the gospel and transforming lives in India"
              width="208"
              height="208"
              fetchpriority="high"
              decoding="async"
              class="w-48 h-[192px] md:w-52 md:h-[208px]"
            />
          </div>
        </div>
      </div>
    </div>
    <!-- Bottom cream spacing -->
    <div class="h-10 lg:h-14"></div>
  </section>

  <style>
    .tagline-dashed-line {
      position: absolute;
      width: 300px;
      height: 0;
      border-top: 3px dashed rgba(180, 160, 155, 0.5);
      transform-origin: left center;
      z-index: 5;
    }
    .tagline-dashed-top-right {
      top: 15%;
      right: -60px;
      transform: rotate(-45deg);
    }
    .tagline-dashed-bottom-right {
      bottom: 15%;
      right: -60px;
      transform: rotate(-45deg);
    }
    .tagline-dashed-top-left {
      top: 15%;
      left: -60px;
      transform: rotate(45deg);
    }
    .tagline-dashed-bottom-left {
      bottom: 15%;
      left: -60px;
      transform: rotate(45deg);
    }
  </style>

  <!-- Hero fonts loaded from system -->
  <style>
    .hero-flip-container {
      perspective: 1200px;
    }
    .hero-flip-text {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: clamp(0.15em, 1vw, 0.3em);
      white-space: nowrap;
    }
    .flip-word {
      display: inline-block;
      font-family: Helvetica, Arial, sans-serif;
      font-size: clamp(3rem, 8vw, 100px);
      font-weight: 400;
      text-shadow: 3px 4px 10px rgba(0,0,0,0.6);
      perspective: 800px;
      /* Fixed wider min-width prevents CLS during text swap (Jesus ↔ India) */
      min-width: 4.2em;
      text-align: center;
    }
    .flip-word.flipping {
      animation: word-flip 0.8s ease-in-out;
    }
    @keyframes word-flip {
      0%   { transform: rotateY(0deg); }
      50%  { transform: rotateY(90deg); }
      100% { transform: rotateY(0deg); }
    }
    .flip-word-left {
      color: #FF8FAB;
    }
    .flip-word-right {
      color: #4CAF50;
    }
    .flip-word-left.swapped {
      color: #4CAF50;
    }
    .flip-word-right.swapped {
      color: #FF8FAB;
    }
    .txt-for {
      font-family: Helvetica, Arial, sans-serif;
      font-size: clamp(2rem, 5.5vw, 70px);
      font-weight: 400;
      color: #ffffff;
      text-shadow: 2px 3px 8px rgba(0,0,0,0.6);
    }
  </style>

  <script>
    // Defer hero video until window.load (after LCP) to avoid competing with the hero image.
    // Video fades in over the poster image once it starts playing.
    const heroVideo = document.getElementById('hero-video');
    if (heroVideo) {
      heroVideo.addEventListener('playing', () => {
        heroVideo.classList.remove('opacity-0');
        heroVideo.classList.add('opacity-100');
      }, { once: true });
      const kickOffVideo = () => {
        heroVideo.setAttribute('autoplay', '');
        heroVideo.setAttribute('preload', 'auto');
        // Force load + play (autoplay attr alone does not retrigger once DOM is past load)
        try { heroVideo.load(); heroVideo.play().catch(() => {}); } catch (e) {}
      };
      if (document.readyState === 'complete') {
        setTimeout(kickOffVideo, 200);
      } else {
        window.addEventListener('load', () => setTimeout(kickOffVideo, 200), { once: true });
      }
    }
  </script>

  <script>
    const left = document.getElementById('word-left');
    const right = document.getElementById('word-right');
    let phase = 0; // 0 = "Jesus for India", 1 = "India for Jesus"

    function flipWords() {
      left.classList.add('flipping');
      right.classList.add('flipping');

      setTimeout(() => {
        if (phase === 0) {
          left.textContent = 'India';
          right.textContent = 'Jesus';
          left.classList.add('swapped');
          right.classList.add('swapped');
        } else {
          left.textContent = 'Jesus';
          right.textContent = 'India';
          left.classList.remove('swapped');
          right.classList.remove('swapped');
        }
        phase = (phase + 1) % 2;
      }, 400); // swap text at midpoint of flip

      setTimeout(() => {
        left.classList.remove('flipping');
        right.classList.remove('flipping');
      }, 800);

      setTimeout(flipWords, 3000);
    }
    setTimeout(flipWords, 3000);
  </script>


  <!-- ── IMPACT STATS (3x3 grid) ─────────────────────────── -->
  <section id="impact-stats" class="section bg-[#F8F9F3]">
    <div class="container mx-auto">
      <!-- Desktop: horizontal grid -->
      <div class="hidden sm:grid sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
        {stats.map(stat => {
          const raw = stat.value.replace(/[$,]/g, '');
          const num = parseInt(raw, 10);
          const prefix = stat.value.startsWith('$') ? '$' : '';
          return (
            <div class="flex items-center gap-4">
              <img src={stat.icon} alt={stat.label} width="64" height="64" loading="lazy" class="w-16 h-[64px] shrink-0" />
              <div>
                <div
                  class="count-up text-[22px] md:text-[35px] font-bold text-[#1D1C1C] leading-tight"
                  data-target={num}
                  data-prefix={prefix}
                >0</div>
                <div class="text-[#666] text-sm font-medium">{stat.label}</div>
              </div>
            </div>
          );
        })}
      </div>
      <!-- Mobile: vertical centered cards with dashed path -->
      <div class="sm:hidden relative">
        <!-- Decorative dashed path -->
        <div class="absolute left-1/2 top-0 bottom-0 -translate-x-1/2 border-l-2 border-dashed border-stone-300 z-0"></div>
        <div class="relative z-10 flex flex-col items-center gap-6">
          {stats.map(stat => {
            const raw = stat.value.replace(/[$,]/g, '');
            const num = parseInt(raw, 10);
            const prefix = stat.value.startsWith('$') ? '$' : '';
            return (
              <div class="flex flex-col items-center text-center">
                <div class="relative w-28 h-28 flex items-center justify-center mb-3">
                  <div class="absolute inset-0 bg-[#2EAB5A]/10 rounded-[40%_60%_50%_50%/60%_40%_60%_40%]"></div>
                  <img src={stat.icon} alt={stat.label} width="80" height="80" loading="lazy" class="relative w-20 h-[80px]" />
                </div>
                <div
                  class="count-up text-2xl font-bold text-[#1D1C1C] leading-tight"
                  data-target={num}
                  data-prefix={prefix}
                >0</div>
                <div class="text-[#666] text-sm font-medium">{stat.label}</div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <script>
    function formatNumber(n: number): string {
      return n.toLocaleString('en-US');
    }

    function animateCountUp(el: HTMLElement) {
      const target = parseInt(el.dataset.target || '0', 10);
      const prefix = el.dataset.prefix || '';
      const duration = 30000;
      const startTime = performance.now();

      function easeOutQuart(t: number): number {
        return 1 - Math.pow(1 - t, 4);
      }

      function tick(now: number) {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const current = Math.floor(easeOutQuart(progress) * target);
        el.textContent = prefix + formatNumber(current);

        if (progress < 1) {
          requestAnimationFrame(tick);
        } else {
          el.textContent = prefix + formatNumber(target);
        }
      }

      requestAnimationFrame(tick);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const counters = entry.target.querySelectorAll('.count-up');
            counters.forEach((el) => animateCountUp(el as HTMLElement));
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );

    function initStatsObserver() {
      const s = document.getElementById('impact-stats');
      if (s) observer.observe(s);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initStatsObserver);
    } else {
      initStatsObserver();
    }
  </script>

  <!-- ── IMPACTING INDIA (video visual break) ──────────── -->
  <section id="impact-video-section" class="relative overflow-hidden" style="min-height: clamp(55vh, 70vh, 70vh);">
    <div class="absolute inset-0 bg-[#F8F9F3]"></div>
    <video
      id="impact-video"
      muted
      loop
      playsinline
      preload="none"
      data-src="https://assets.spiritmediapublishing.com/video/empowering-indias-church-global-hope-india.mp4"
      class="absolute inset-0 w-full h-full object-cover"
    ></video>
    <div class="absolute inset-0 bg-black/[0.03]"></div>
    <div class="absolute inset-0 flex items-start justify-center md:justify-start z-10 px-4 pt-4 md:pt-0 md:-top-5 md:left-36">
      <span class="inline-block bg-[#1d803f] text-white font-bold text-xl md:text-[50px] px-5 py-3 md:p-5 rounded-sm shadow-lg text-center md:text-left">Transforming Lives in India</span>
    </div>
  </section>

  <script>
    // Lazy-load the impact video when it scrolls near the viewport
    (() => {
      const v = document.getElementById('impact-video');
      const section = document.getElementById('impact-video-section');
      if (!v || !section) return;
      const boot = () => {
        if (v.dataset.booted) return;
        v.dataset.booted = '1';
        const src = document.createElement('source');
        src.src = v.getAttribute('data-src');
        src.type = 'video/mp4';
        v.appendChild(src);
        v.setAttribute('preload', 'metadata');
        try { v.load(); v.play().catch(() => {}); } catch (e) {}
      };
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { boot(); io.disconnect(); } });
        }, { rootMargin: '300px' });
        io.observe(section);
      } else {
        window.addEventListener('load', () => setTimeout(boot, 1500), { once: true });
      }
    })();
  </script>

