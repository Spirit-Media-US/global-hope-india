---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found — Global Hope India" description="The page you're looking for doesn't exist.">
  <Fragment slot="head"><meta name="robots" content="noindex, nofollow" /></Fragment>
  <section class="min-h-screen flex items-center justify-center bg-[#1D1C1C] text-white px-6 pt-20">
    <div class="text-center">
      <div class="text-8xl font-bold text-[#FEC415] mb-4">404</div>
      <h1 class="text-white mb-4">Page Not Found</h1>
      <p class="text-white/70 text-lg mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="btn">Go Home</a>
    </div>
  </section>
</Layout>
