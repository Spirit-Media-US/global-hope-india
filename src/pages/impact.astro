---
import Layout from '../layouts/Layout.astro';

const stories = [
  {
    title: 'Our Partners in India',
    tags: ['Partners', 'South India'],
    excerpt: 'Global Hope India works with indigenous church-planting partners across India covering North, South, East, West and Northeast India.',
    date: 'March 18, 2025',
    image: 'https://globalhopeindia.org/wp-content/uploads/2025/03/GHI-Blog-3-03.18.25.webp',
    url: 'https://globalhopeindia.org/our-partners-in-india/',
  },
  {
    title: 'Support Key Projects in Manipur',
    tags: ['Leadership', 'Northeast'],
    excerpt: 'The work in Manipur is critical to reaching Northeast India for Christ. See how your support is making a difference.',
    date: 'March 18, 2025',
    image: 'https://globalhopeindia.org/wp-content/uploads/2025/03/GHI-Blog-2-03.18.25.webp',
    url: 'https://globalhopeindia.org/support-key-projects-in-manipur/',
  },
  {
    title: 'Medical Camp Miracles: Healing Bodies and Souls',
    tags: ['Medical', 'Outreach'],
    excerpt: 'Medical camps in India are opening doors for the gospel by meeting physical needs and demonstrating the love of Jesus.',
    date: 'March 18, 2025',
    image: 'https://globalhopeindia.org/wp-content/uploads/2025/03/GHI-Blog-1-03.18.25.webp',
    url: 'https://globalhopeindia.org/medical-camp-miracles-healing-bodies-and-souls/',
  },
  {
    title: "Hope for India's Special Needs Community: The Mission of Raja's Home",
    tags: ['Community', 'Hyderabad'],
    excerpt: "Raja's Home is providing hope and care for India's special needs community through the love of Christ.",
    date: 'March 4, 2025',
    image: 'https://globalhopeindia.org/wp-content/uploads/2025/03/GHI-04.04.25-2.webp',
    url: 'https://globalhopeindia.org/hope-for-indias-special-needs/',
  },
  {
    title: 'Empowering the Deaf Community: The Mission of DBM in Nagaland, India',
    tags: ['Community', 'Nagaland'],
    excerpt: 'DBM in Nagaland is empowering the deaf community through education, vocational training, and the gospel.',
    date: 'March 4, 2025',
    image: 'https://globalhopeindia.org/wp-content/uploads/2025/03/GHI-Blog-03.04.25.webp',
    url: 'https://globalhopeindia.org/empowering-the-deaf-community-the-mission-of-dbm-in-nagaland-india/',
  },
  {
    title: "Elim School: Supporting Pastor Mayon's Mission in Manipur",
    tags: ['Education', 'Manipur'],
    excerpt: "Pastor Mayon's Elim School in Manipur is providing education and hope to children in one of India's most challenging regions.",
    date: 'March 4, 2025',
    image: 'https://globalhopeindia.org/wp-content/uploads/2025/03/GHI-Blog-03.04.25-3-1.webp',
    url: 'https://globalhopeindia.org/elim-school-supporting-pastor-mayons-mission-in-manipur/',
  },
];
---

<Layout
  title="Impact GHI Magazine — Global Hope India"
  description="Read Impact GHI Magazine to see how Global Hope India is making a difference. Your support helps extend God's kingdom."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Impact GHI Magazine — Global Hope India",
      "url": "https://globalhopeindia.org/impact",
      "description": "Read Impact GHI Magazine to see how Global Hope India is making a difference.",
      "publisher": { "@type": "Organization", "name": "Global Hope India", "url": "https://globalhopeindia.org" }
    })}></script>
  </Fragment>

  <!-- ── HERO ────────────────────────────────────────────── -->
  <section class="relative min-h-[55vh] lg:min-h-[65vh] overflow-hidden">
    <img
      src="/images/impact-hero.png"
      alt="Global Hope India Impact"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
    <div id="hero-parallax" class="absolute bottom-8 left-0 right-0 z-10 container mx-auto px-6 lg:px-12 will-change-transform">
      <h1 style="color: white !important;" class="max-w-3xl font-bold text-[28px] md:text-[36px] lg:text-[50px] leading-[1.2]">Impact<br/>GHI Magazine</h1>
    </div>
  </section>

  <!-- ── STORIES GRID ────────────────────────────────────── -->
  <section class="section bg-white">
    <div class="container mx-auto max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {stories.map(story => (
          <div class="group flex flex-col">
            <!-- Card image -->
            <div class="overflow-hidden rounded-lg mb-4">
              <img
                src={story.image}
                alt={story.title}
                class="w-full h-[200px] object-cover object-bottom transition-transform duration-300 group-hover:scale-105"
              />
            </div>
            <!-- Card content -->
            <h2 class="text-[#1D1C1C] font-bold text-base leading-snug mb-3">{story.title}</h2>
            <div class="flex items-center gap-1.5 text-[#2EAB5A] text-xs mb-4">
              <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 448 512" fill="currentColor"><path d="M12 192h424c6.6 0 12 5.4 12 12v260c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V204c0-6.6 5.4-12 12-12zm436-44v-36c0-26.5-21.5-48-48-48h-48V12c0-6.6-5.4-12-12-12h-40c-6.6 0-12 5.4-12 12v52H160V12c0-6.6-5.4-12-12-12h-40c-6.6 0-12 5.4-12 12v52H48C21.5 64 0 85.5 0 112v36c0 6.6 5.4 12 12 12h424c6.6 0 12-5.4 12-12z"/></svg>
              <span>{story.date}</span>
            </div>
            <a href={story.url} target="_blank" rel="noopener noreferrer" class="mt-auto inline-flex items-center gap-1.5 text-[#2EAB5A] text-sm font-semibold hover:underline">
              Read Full Story Here
              <svg class="w-3.5 h-3.5" viewBox="0 0 448 512" fill="currentColor"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
            </a>
          </div>
        ))}
      </div>
      <!-- Load More button -->
      <div class="text-center mt-12">
        <button class="bg-[#1a2456] text-white font-semibold text-sm rounded-full px-8 py-3 hover:bg-[#111b40] transition-colors">Load More</button>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Hero parallax
  const heroEl = document.getElementById('hero-parallax');
  if (heroEl && window.matchMedia('(min-width: 768px)').matches) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          heroEl.style.transform = `translateY(${window.scrollY * -0.3}px)`;
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }
</script>
