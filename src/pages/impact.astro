---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity.ts';

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const formatDate = (d: string) => {
  const dt = new Date(d);
  return `${MONTHS[dt.getUTCMonth()]} ${dt.getUTCDate()}, ${dt.getUTCFullYear()}`;
};

let stories: any[] = [];
try {
  const raw = await sanityClient.fetch(`
    *[_type == "blogPost"] | order(publishDate desc) {
      title,
      "slug": slug.current,
      excerpt,
      publishDate,
      "image": coalesce(heroImage.asset->url, externalImageUrl),
      "url": "/blog/" + slug.current,
      tags
    }
  `);
  stories = raw.map((p: any) => ({
    ...p,
    date: p.publishDate ? formatDate(p.publishDate) : '',
  }));
} catch (e) {}
---

<Layout
  title="Impact Stories & Magazine — Global Hope India"
  description="Read real stories of lives transformed through Global Hope India's work in church planting, orphan care, medical camps, and Bible distribution across India."
  keywords="india missions, church planting india, christian nonprofit india, sponsor orphan india"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Impact GHI Magazine — Global Hope India",
      "url": "https://globalhopeindia.org/impact",
      "description": "Read Impact GHI Magazine to see how Global Hope India is making a difference.",
      "publisher": { "@type": "Organization", "name": "Global Hope India", "url": "https://globalhopeindia.org" }
    })}></script>
    <style>
      .blog-card-title, .blog-card-title * {
        font-size: 16px !important;
        font-weight: 600 !important;
        color: #3B9C5A !important;
        line-height: 1.4 !important;
      }
    </style>
  </Fragment>

  <!-- ── HERO ────────────────────────────────────────────── -->
  <section class="relative min-h-[55vh] lg:min-h-[65vh] overflow-hidden">
    <img
      src="https://assets.spiritmediapublishing.com/images/ghi-impact-hero.png"
      alt="Global Hope India Impact"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
    <div id="hero-parallax" class="absolute bottom-8 left-0 right-0 z-10 container mx-auto px-6 lg:px-12 will-change-transform">
      <h1 style="color: white !important;" class="max-w-3xl font-bold text-[28px] md:text-[36px] lg:text-[50px] leading-[1.2]">Impact<br/>GHI Magazine</h1>
    </div>
  </section>

  <!-- ── STORIES GRID ────────────────────────────────────── -->
  <section class="bg-[#f5f5f0] py-12 lg:py-20 px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div id="stories-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
      <div id="load-more-wrap" class="text-center mt-12">
        <button id="load-more-btn" class="bg-[#2EAB5A] text-white font-semibold text-sm rounded-full px-8 py-3 hover:bg-[#248f4a] transition-colors inline-flex items-center gap-2">
          <span id="load-more-text">Load More</span>
          <svg id="load-more-spinner" class="hidden w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────────── -->
  <section class="bg-[#06038D] text-center py-12 lg:py-16 px-6">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-white font-bold text-[26px] md:text-[36px] mb-4">Give to Make More Impact</h2>
      <p class="text-white/80 text-base lg:text-lg leading-relaxed mb-8">Every gift helps fund church planting, Bible distribution, orphan care, and community development across India.</p>
      <a href="https://givebutter.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" class="inline-block bg-[#2EAB5A] hover:bg-[#248f4a] text-white font-semibold text-lg px-10 py-4 rounded-full transition-colors shadow-md">Give to India Missions</a>
    </div>
  </section>

  <script id="stories-data" type="application/json" set:html={JSON.stringify(stories)}></script>

  <style>
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .card-fade-in {
      animation: fadeInUp 0.4s ease-out forwards;
    }
  </style>
</Layout>

<script>
  // Hero parallax
  const heroEl = document.getElementById('hero-parallax');
  if (heroEl && window.matchMedia('(min-width: 768px)').matches) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          heroEl.style.transform = `translateY(${window.scrollY * -0.3}px)`;
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }

  // Load More functionality
  const ALL_STORIES = JSON.parse(document.getElementById('stories-data')?.textContent || '[]');
  const PER_LOAD = 6;
  let shown = 0;
  const grid = document.getElementById('stories-grid');
  const btn = document.getElementById('load-more-btn');
  const wrap = document.getElementById('load-more-wrap');
  const spinner = document.getElementById('load-more-spinner');
  const btnText = document.getElementById('load-more-text');

  function renderCard(s) {
    return `<a href="${s.url}" class="card-fade-in group bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col">
      <div class="overflow-hidden">
        <img src="${s.image}" alt="${s.title}" class="w-full h-[180px] object-cover object-bottom transition-transform duration-300 group-hover:scale-105" />
      </div>
      <div class="p-4 flex flex-col flex-1">
        <p style="font-size:16px!important;font-weight:600!important;color:#3B9C5A!important;line-height:1.4!important;margin:0 0 8px 0!important;">${s.title}</p>
        <div class="flex items-center gap-1.5 text-[#2EAB5A] text-xs mb-3">
          <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 448 512" fill="currentColor"><path d="M12 192h424c6.6 0 12 5.4 12 12v260c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V204c0-6.6 5.4-12 12-12zm436-44v-36c0-26.5-21.5-48-48-48h-48V12c0-6.6-5.4-12-12-12h-40c-6.6 0-12 5.4-12 12v52H160V12c0-6.6-5.4-12-12-12h-40c-6.6 0-12 5.4-12 12v52H48C21.5 64 0 85.5 0 112v36c0 6.6 5.4 12 12 12h424c6.6 0 12-5.4 12-12z"/></svg>
          <span>${s.date}</span>
        </div>
        <div class="mt-auto inline-flex items-center gap-1.5 text-[#2EAB5A] text-sm font-semibold group-hover:underline">
          Read Full Story Here
          <svg class="w-3.5 h-3.5" viewBox="0 0 448 512" fill="currentColor"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
        </div>
      </div>
    </a>`;
  }

  function loadBatch() {
    const batch = ALL_STORIES.slice(shown, shown + PER_LOAD);
    batch.forEach(s => {
      grid.insertAdjacentHTML('beforeend', renderCard(s));
    });
    shown += batch.length;
    if (shown >= ALL_STORIES.length) {
      wrap.classList.add('hidden');
    }
  }

  // Initial load
  loadBatch();

  // Button click
  btn?.addEventListener('click', () => {
    spinner.classList.remove('hidden');
    btnText.textContent = 'Loading...';
    setTimeout(() => {
      loadBatch();
      spinner.classList.add('hidden');
      btnText.textContent = 'Load More';
    }, 400);
  });
</script>
