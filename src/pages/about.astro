---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity.ts';

// Fetch all about page content from Sanity
let settings: any = {};
let culturePoints: any[] = [];
let faithStatements: any[] = [];
let teamMembers: any[] = [];
let faqs: any[] = [];
let empowerCards: any[] = [];
let serviceAreas: any[] = [];
let hero: any = {};

try {
  [settings, culturePoints, faithStatements, teamMembers, faqs, empowerCards, serviceAreas, hero] = await Promise.all([
    sanityClient.fetch(`*[_type == "siteSettings"][0]`),
    sanityClient.fetch(`*[_type == "culturePoint"] | order(order asc) { number, title, description }`),
    sanityClient.fetch(`*[_type == "statementOfFaith"] | order(order asc) { text }`),
    sanityClient.fetch(`*[_type == "teamMember"] | order(order asc) { text }`),
    sanityClient.fetch(`*[_type == "faqItem" && page == "about"] | order(order asc) { question, answer }`),
    sanityClient.fetch(`*[_type == "empowerCard"] | order(order asc) { title, description }`),
    sanityClient.fetch(`*[_type == "serviceArea"] | order(order asc) { title, description }`),
    sanityClient.fetch(`*[_type == "pageHero" && page == "about"][0] { heading, heroImageUrl }`),
  ]);
} catch (e) {}

// Fallbacks
settings = settings || {};
hero = hero || {};
const vision = settings.visionStatement || 'Everyone in India worshiping Jesus as Savior and Lord.';
const mission = settings.missionStatement || 'Global Hope India exists to see Indian Nationals, absent to the gospel, transformed into ambassadors for the gospel.';
const empowering = settings.empoweringText || '';
const heroHeading = hero.heading || 'Church Vision and Mission: Shaping Faith\'s Future with Global Hope India';
const heroImage = hero.heroImageUrl || 'https://assets.spiritmediapublishing.com/images/ghi-about-hero.webp';
const radicalHeading = settings.radicalHeading || 'Did Someone Say, "Radical"?';
const radicalP1 = settings.radicalParagraph1 || '';
const radicalP2 = settings.radicalParagraph2 || '';
const founderP1 = settings.founderStoryPart1 || '';
const founderP2 = settings.founderStoryPart2 || '';
const founderP3 = settings.founderStoryPart3 || '';
const founderP4 = settings.founderStoryPart4 || '';
---

<Layout
  title="About Us — Advancing the Gospel & Empowering God's Work in India Since 1998"
  description="Learn how Global Hope India has spent 25+ years empowering God's work in India — supporting Christian missionaries, church planting, Bible distribution, and transforming lives among unreached people."
  keywords="empowering God's work in India, advancing the gospel in India, support Christian missionaries India, church planting movement India, transforming lives in India, unreached people India, Bibles for India, donate to India missions, short term mission trip India"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AboutPage",
      "name": "About Global Hope India",
      "url": "https://globalhopeindia.org/about",
      "description": "Learn how Global Hope India has spent 25+ years empowering God's work in India — supporting Christian missionaries, church planting, Bible distribution, and transforming lives among unreached people."
    })}></script>
  </Fragment>

  <!-- ── HERO ────────────────────────────────────────────── -->
  <section class="relative min-h-[65vh] flex items-end overflow-hidden">
    <img
      src="https://assets.spiritmediapublishing.com/images/ghi-about-hero.webp"
      alt="Indian young people — advancing the gospel among unreached people in India"
      class="absolute inset-0 w-full h-full object-cover object-[center_30%]"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
    <div id="about-hero-parallax" class="relative z-10 container mx-auto px-6 lg:px-12 pb-10 pt-64 will-change-transform">
      <h1 style="color: white !important;" class="max-w-3xl font-bold text-[26px] md:text-[30px] lg:text-[50px] leading-[1.3] lg:leading-[1.2]" set:html={heroHeading.replace(/\n/g, '<br/>')} />
    </div>
  </section>

  <script>
    const aboutHero = document.getElementById('about-hero-parallax');
    if (aboutHero && window.matchMedia('(min-width: 768px)').matches) {
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            aboutHero.style.transform = `translateY(${window.scrollY * -0.3}px)`;
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    }

    // Faith collage parallax — each photo at different speed
    if (window.matchMedia('(min-width: 768px)').matches) {
      const photos = document.querySelectorAll('.faith-photo');
      const collage = document.getElementById('faith-collage');
      let faithTicking = false;
      window.addEventListener('scroll', () => {
        if (!faithTicking) {
          requestAnimationFrame(() => {
            if (collage) {
              const rect = collage.getBoundingClientRect();
              const inView = rect.top < window.innerHeight && rect.bottom > 0;
              if (inView) {
                const progress = (window.innerHeight - rect.top) / (window.innerHeight + rect.height);
                photos.forEach(img => {
                  const speed = parseFloat(img.dataset.speed || '0');
                  const offset = (progress - 0.5) * -60 * speed / 0.25;
                  img.style.transform = `translateY(${offset}px)`;
                });
              }
            }
            faithTicking = false;
          });
          faithTicking = true;
        }
      }, { passive: true });
    }
  </script>

  <!-- ── VISION / EMPOWERING / MISSION ROW ───────────────── -->
  <section class="relative section bg-white overflow-hidden">
    <div class="container mx-auto relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 items-start">
        <!-- Our Vision -->
        <div class="text-center px-4">
          <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-[#FEC415]/20 flex items-center justify-center">
            <svg class="w-7 h-7 text-[#FEC415]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-[#1D1C1C] mb-3">Our Vision</h3>
          <p class="text-[#555] leading-relaxed text-sm">"{vision}"</p>
        </div>

        <!-- Empowering Radical Transformation -->
        <div class="text-center px-4">
          <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-[#FEC415]/20 flex items-center justify-center">
            <svg class="w-7 h-7 text-[#FEC415]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>
          </div>
          <h3 class="text-xl font-bold text-[#1D1C1C] mb-3">Empowering Radical Transformation</h3>
          <p class="text-[#555] leading-relaxed text-sm">{empowering}</p>
        </div>

        <!-- Our Mission -->
        <div class="text-center px-4">
          <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-[#FEC415]/20 flex items-center justify-center">
            <svg class="w-7 h-7 text-[#FEC415]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-[#1D1C1C] mb-3">Our Mission</h3>
          <p class="text-[#555] leading-relaxed text-sm">"{mission}"</p>
        </div>
      </div>
    </div>
    <!-- Large green swoosh at bottom-right -->
    <div class="absolute -bottom-4 -right-4 pointer-events-none opacity-50">
      <svg width="200" height="120" viewBox="0 0 200 120" fill="none"><path d="M10 90c40-80 120-80 180-20" stroke="#2EAB5A" stroke-width="8" stroke-linecap="round" fill="none"/><path d="M170 55l22 15-20 8" fill="#2EAB5A"/></svg>
    </div>
  </section>

  <!-- ── OUR CULTURE ─────────────────────────────────────── -->
  <section class="relative section bg-[#F8F5EF] overflow-hidden">
    <!-- Large faded green circle decoration -->
    <div class="absolute -left-32 top-1/2 -translate-y-1/2 w-[400px] h-[400px] rounded-full bg-[#2EAB5A]/10 pointer-events-none"></div>
    <div class="relative z-10 container mx-auto max-w-5xl">
      <h2 class="text-[#1D1C1C] mb-10">Our Culture</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-0">
        <!-- Left column -->
        <div class="space-y-6">
          {culturePoints.filter((_: any, i: number) => i < 4).map((c: any) => (
            <div class="flex items-start gap-3">
              <span class="text-[#2EAB5A] font-bold text-lg mt-0.5 shrink-0">{c.number}.</span>
              <p class="text-[#1D1C1C] leading-relaxed"><strong class="text-[#2EAB5A]">{c.title}</strong> {c.description}</p>
            </div>
          ))}
        </div>
        <!-- Right column -->
        <div class="space-y-6">
          {culturePoints.filter((_: any, i: number) => i >= 4).map((c: any) => (
            <div class="flex items-start gap-3">
              <span class="text-[#2EAB5A] font-bold text-lg mt-0.5 shrink-0">{c.number}.</span>
              <p class="text-[#1D1C1C] leading-relaxed"><strong class="text-[#2EAB5A]">{c.title}</strong> {c.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── DID SOMEONE SAY RADICAL? ─────────────────────────── -->
  <section class="section bg-white">
    <div class="container mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <!-- Left: group photo -->
        <div>
          <img
            src="https://assets.spiritmediapublishing.com/images/ghi-radical-group.jpg"
            alt="Global Hope India short term mission trip team empowering God's work in India"
            class="rounded-lg w-full h-auto object-cover"
          />
        </div>
        <!-- Right: text content -->
        <div>
          <h2 class="text-[#1D1C1C] text-3xl lg:text-4xl font-bold mb-6">{radicalHeading}</h2>
          <p class="text-[#555] leading-[1.8] mb-5">{radicalP1}</p>
          <p class="text-[#555] leading-[1.8]">{radicalP2}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── ACCORDION 2x2 GRID ────────────────────────────────── -->
  <section class="section bg-white">
    <div class="container mx-auto max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="space-y-6">
          {faqs.filter((_: any, i: number) => i % 2 === 0).map((faq: any) => (
            <div class="accordion-card bg-[#F5F5EE] rounded-xl p-6">
              <button class="accordion-btn w-full flex items-center justify-between text-left" aria-expanded="true">
                <h3 class="text-lg font-bold text-[#1D1C1C]">{faq.question}</h3>
                <span class="accordion-sign text-[#1D1C1C] text-2xl leading-none shrink-0 ml-4">—</span>
              </button>
              <div class="accordion-body mt-4">
                <p class="text-[#555] leading-relaxed text-sm">{faq.answer}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="space-y-6">
          {faqs.filter((_: any, i: number) => i % 2 === 1).map((faq: any) => (
            <div class="accordion-card bg-[#F5F5EE] rounded-xl p-6">
              <button class="accordion-btn w-full flex items-center justify-between text-left" aria-expanded="true">
                <h3 class="text-lg font-bold text-[#1D1C1C]">{faq.question}</h3>
                <span class="accordion-sign text-[#1D1C1C] text-2xl leading-none shrink-0 ml-4">—</span>
              </button>
              <div class="accordion-body mt-4">
                <p class="text-[#555] leading-relaxed text-sm">{faq.answer}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.accordion-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const card = btn.closest('.accordion-card');
        const body = card?.querySelector('.accordion-body');
        const sign = btn.querySelector('.accordion-sign');
        const isOpen = btn.getAttribute('aria-expanded') === 'true';
        if (isOpen) {
          body?.classList.add('hidden');
          btn.setAttribute('aria-expanded', 'false');
          if (sign) sign.textContent = '+';
        } else {
          body?.classList.remove('hidden');
          btn.setAttribute('aria-expanded', 'true');
          if (sign) sign.textContent = '—';
        }
      });
    });
  </script>

  <!-- ── 4 WAYS WE EMPOWER BELIEVERS ─────────────────────── -->
  <section class="section bg-[#F5F5EE]">
    <div class="container mx-auto max-w-4xl">
      <h2 class="text-[#1D1C1C] text-3xl lg:text-5xl font-bold mb-10">4 Ways we Empower Believers Globally</h2>
      <ol class="space-y-3 text-[#444]">
        {empowerCards.map((card: any, i: number) => (
          <li class="flex items-start gap-2">
            <span class="font-bold text-[#1D1C1C]">{i + 1}.</span>
            <p>{card.title}{card.title === 'Pray' ? ' for Believers (Americans & Indians) to receive & share Christ.' : card.title === 'Give' ? " to God's work through GHI." : card.title === 'Go' ? ' and serve the Church in India.' : ' for radical transformation.'}</p>
          </li>
        ))}
      </ol>

      <!-- 2x2 Card Grid: Pray, Give, Go, Resources -->
      <div class="relative grid grid-cols-1 md:grid-cols-2 gap-6 mt-12">
        {empowerCards.map((card: any, i: number) => (
          <div class="bg-white rounded-xl p-8">
            <div class="w-10 h-10 rounded-full bg-[#FEC415] flex items-center justify-center mb-4">
              <span class="text-white font-bold text-lg">{i + 1}</span>
            </div>
            <h3 class="text-xl font-bold text-[#1D1C1C] mb-3">{card.title}</h3>
            <p class="text-[#555] leading-relaxed text-sm">{card.description}</p>
          </div>
        ))}
        <!-- Green swoosh bottom-right -->
        <div class="absolute -bottom-8 -right-8 pointer-events-none opacity-40 hidden md:block">
          <svg width="180" height="100" viewBox="0 0 180 100" fill="none"><path d="M10 80c40-70 110-70 160-15" stroke="#2EAB5A" stroke-width="7" stroke-linecap="round" fill="none"/><path d="M152 50l20 15-18 6" fill="#2EAB5A"/></svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 3 WAYS OUR TEAMS SERVE ──────────────────────────── -->
  <section class="section bg-white">
    <div class="container mx-auto">
      <h2 class="text-[#1D1C1C] text-center mb-12">3 Ways Our Teams Serve The Church in India</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Leadership Development -->
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-5 rounded-full bg-[#2EAB5A]/10 flex items-center justify-center">
            <svg class="w-10 h-10 text-[#2EAB5A]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-[#1D1C1C] mb-3">{serviceAreas[0]?.title || 'Leadership Development'}</h3>
          <p class="text-[#555] leading-relaxed">{serviceAreas[0]?.description || ''}</p>
        </div>
        <!-- Child Development -->
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-5 rounded-full bg-[#2EAB5A]/10 flex items-center justify-center">
            <svg class="w-10 h-10 text-[#2EAB5A]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-[#1D1C1C] mb-3">{serviceAreas[1]?.title || 'Child Development'}</h3>
          <p class="text-[#555] leading-relaxed">{serviceAreas[1]?.description || ''}</p>
        </div>
        <!-- Community Development -->
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-5 rounded-full bg-[#2EAB5A]/10 flex items-center justify-center">
            <svg class="w-10 h-10 text-[#2EAB5A]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>
          </div>
          <h3 class="text-lg font-bold text-[#1D1C1C] mb-3">{serviceAreas[2]?.title || 'Community Development'}</h3>
          <p class="text-[#555] leading-relaxed">{serviceAreas[2]?.description || ''}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── HOW GHI BEGAN ────────────────────────────────────── -->
  <section class="section bg-white overflow-hidden">
    <div class="container mx-auto">
      <!-- Row 1: Text left, Photo right -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start mb-16">
        <div>
          <h2 class="text-[#1D1C1C] text-3xl lg:text-4xl font-bold mb-6">How GHI Began</h2>
          <div class="space-y-5 text-[#444] leading-relaxed">
            <p>{founderP1}</p>
            <p>{founderP2}</p>
          </div>
        </div>
        <div>
          <img
            src="https://assets.spiritmediapublishing.com/images/ghi-began.jpg"
            alt="Indian woman and child receiving supplies — transforming lives in India through Christian missions"
            class="rounded-xl w-full h-auto object-cover"
          />
        </div>
      </div>
      <!-- Row 2: Photo left with green swoosh, Text right -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div class="relative">
          <!-- Green swoosh behind photo -->
          <div class="absolute -bottom-6 -left-6 pointer-events-none opacity-40 hidden lg:block">
            <svg width="180" height="100" viewBox="0 0 180 100" fill="none"><path d="M10 80c40-70 110-70 160-15" stroke="#2EAB5A" stroke-width="7" stroke-linecap="round" fill="none"/><path d="M152 50l20 15-18 6" fill="#2EAB5A"/></svg>
          </div>
          <img
            src="https://assets.spiritmediapublishing.com/images/ghi-20191230-img_8353cary-the-water-untitled-768x1024.jpg"
            alt="Indian woman in traditional dress — pray for India's unreached people"
            class="relative z-10 rounded-xl w-full h-auto object-cover max-h-[500px]"
          />
        </div>
        <div class="space-y-5 text-[#444] leading-relaxed">
          <p>{founderP3}</p>
          <p class="font-semibold text-[#1D1C1C]">{founderP4}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── OUR TEAM ─────────────────────────────────────────── -->
  <section class="relative section bg-[#f9f9f9] overflow-hidden">
    <div class="container mx-auto max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.4fr] gap-8 lg:gap-16 items-center">
        <!-- Left: heading + decorative green leaf -->
        <div class="relative lg:min-h-[200px]">
          <h2 class="text-[#1D1C1C] font-bold text-[26px] md:text-[30px] lg:text-[50px] leading-tight mb-0">Our Team</h2>
          <!-- Decorative green leaf/bird — matches original site -->
          <div class="hidden lg:block absolute -bottom-12 -left-16 pointer-events-none">
            <svg width="220" height="140" viewBox="0 0 220 140" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M-20 130 C10 50, 70 5, 180 35 C130 15, 50 45, 0 120 Z" fill="#2EAB5A"/>
              <path d="M-20 130 C20 65, 90 35, 180 35" stroke="#1e7d3e" stroke-width="1.5" fill="none"/>
              <circle cx="112" cy="34" r="4.5" fill="#2EAB5A"/>
            </svg>
          </div>
        </div>
        <!-- Right: bullet list -->
        <div>
          <ul class="list-disc list-outside pl-5 space-y-3 text-[#1D1C1C] text-base leading-relaxed">
            {teamMembers.map((m: any) => (
              <li>{m.text}</li>
            ))}
          </ul>
        </div>
      </div>
      <p class="text-[#666] text-sm mt-10 italic text-center">(please <a href="mailto:info@globalhopeindia.org" class="underline hover:text-[#2EAB5A] transition-colors">contact us</a> directly to request specific details about Our Team.)</p>
    </div>
  </section>

  <!-- ── STATEMENT OF FAITH ───────────────────────────────── -->
  <section class="section bg-[#F8F5EF]">
    <div class="container mx-auto max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-14 gap-y-10">
        <!-- Left column: heading + 6 paragraphs -->
        <div>
          <h2 class="text-[#1D1C1C] font-bold text-[26px] md:text-[30px] lg:text-[50px] leading-tight mb-6">Statement of Faith</h2>
          <div class="space-y-2 text-[#444] text-[15px] leading-[1.7]">
            {faithStatements.slice(0, 6).map((s: any) => (
              <p>{s.text}</p>
            ))}
          </div>
        </div>
        <!-- Right column: 7 paragraphs + photo collage -->
        <div>
          <div class="space-y-2 text-[#444] text-[15px] leading-[1.7] lg:mt-[116px]">
            {faithStatements.slice(6).map((s: any) => (
              <p>{s.text}</p>
            ))}
          </div>
          <!-- Photo collage: 3 overlapping images with parallax -->
          <div id="faith-collage" class="relative mt-8 h-[300px] lg:h-[350px] overflow-hidden">
            <img
              src="https://assets.spiritmediapublishing.com/images/ghi-201811_globalhopeindia_church-56-scaled.jpg"
              alt="Global Hope India church gathering — church planting movement India"
              class="faith-photo absolute left-0 top-0 w-[38%] h-[85%] object-cover rounded-lg shadow-md z-10 will-change-transform"
              data-speed="0.15"
            />
            <img
              src="https://assets.spiritmediapublishing.com/images/ghi-201811_globalhopeindia_church-20-scaled.jpg"
              alt="Indian woman in prayer — pray for India unreached people"
              class="faith-photo absolute left-[28%] top-[15%] w-[40%] h-[90%] object-cover object-top rounded-lg shadow-lg z-20 will-change-transform"
              data-speed="0.25"
            />
            <img
              src="https://assets.spiritmediapublishing.com/images/ghi-20200106-img_0052cary-the-water-untitled-scaled.jpg"
              alt="Global Hope India community outreach — transforming lives in India"
              class="faith-photo absolute right-0 top-0 w-[38%] h-[85%] object-cover rounded-lg shadow-md z-10 will-change-transform"
              data-speed="0.35"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SUPPORT CTA ────────────────────────────────────── -->
  <section class="section bg-[#06038D] text-center">
    <div class="container mx-auto max-w-3xl">
      <h2 class="text-white font-bold text-[26px] md:text-[36px] mb-4">Support Our Mission</h2>
      <p class="text-white/80 text-base lg:text-lg leading-relaxed mb-8">For over 25 years, Global Hope India has been sending people, funding, and resources to empower the church in India. Your generosity helps make Christ known among 1.4 billion people.</p>
      <a href="https://givebutter.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" class="inline-block bg-[#2EAB5A] hover:bg-[#248f4a] text-white font-semibold text-lg px-10 py-4 rounded-full transition-colors shadow-md">Give to India Missions</a>
    </div>
  </section>

</Layout>
