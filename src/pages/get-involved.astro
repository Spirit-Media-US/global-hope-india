---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Pray, Give & Go — Donate to India Missions | GHI"
  description="Three ways to support God's work in India: pray for unreached people, fund Bible distribution and church planting, or join a short-term mission trip to India."
  ogImage="https://assets.spiritmediapublishing.com/images/ghi-get-involved-hero.png"
  keywords="donate to India missions, short term mission trip India, pray for India unreached people, give to church planting India, fund Bible distribution India, support Christian missionaries India, giving to God's work in India, Bibles for India, sponsor child India Christian"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Get Involved — Global Hope India",
      "url": "https://globalhopeindia.org/get-involved",
      "description": "Three ways to support God's work in India: pray for unreached people, donate to fund Bible distribution and church planting, or join a short term mission trip to India.",
      "publisher": { "@type": "Organization", "name": "Global Hope India", "url": "https://globalhopeindia.org" }
    })}></script>
    <script src="https://mail.spiritmediaone.com/js/form_embed.js" defer></script>
  </Fragment>

  <!-- ── HERO ────────────────────────────────────────────── -->
  <section class="relative min-h-[60vh] lg:min-h-[75vh] overflow-hidden">
    <img
      src="https://assets.spiritmediapublishing.com/images/ghi-get-involved-hero.png"
      alt="Indian girl holding flag — pray for India's 1 billion unreached people"
      width="1600" height="900" fetchpriority="high"
      class="absolute inset-0 w-full h-full object-cover object-[center_20%]"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-white/80 via-white/40 to-transparent"></div>
    <div id="hero-parallax" class="absolute bottom-10 lg:bottom-16 left-0 right-0 z-10 container mx-auto px-6 lg:px-12 will-change-transform">
      <h1 class="max-w-lg font-bold text-[#1D1C1C] text-[28px] md:text-[36px] lg:text-[50px] leading-[1.2]">Join Global Hope India:<br/>Give, Pray, and Support<br/>for a Brighter Future</h1>
    </div>
  </section>

  <!-- ── THREE COLUMNS: PRAY / GIVE / GO ─────────────────── -->
  <section class="section bg-white">
    <div class="container mx-auto max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">

        <!-- ── COLUMN 1: PRAY ──────────────────────────────── -->
        <div class="flex flex-col">
          <!-- Photo with orange badge -->
          <div class="relative mb-8">
            <img
              src="https://assets.spiritmediapublishing.com/images/ghi-img_4700-scaled.jpg"
              alt="Indian children praying — pray for India unreached people"
              width="600" height="450" loading="lazy"
              class="w-full aspect-[4/3] object-cover rounded-xl"
            />
            <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 w-12 h-12 rounded-full bg-[#FFA500] flex items-center justify-center shadow-lg">
              <span class="text-white font-bold text-xl">1</span>
            </div>
          </div>
          <h3 class="text-[#1D1C1C] font-bold text-2xl text-center mb-3">Pray</h3>
          <p class="text-[#444] text-sm leading-relaxed text-center mb-6">Pray for India. God loves India. Jesus died for India. Pray for God to open the eyes and hearts of all people of India to see, experience, and love Jesus as the one true God.</p>
          <!-- Pray Form -->
          <div class="border border-[#e0e0e0] rounded-xl bg-[#fafafa] p-5 flex-1">
            <p class="text-[#1D1C1C] font-bold text-sm text-center mb-4">I will pray. Send me prayer points.</p>
            <form id="pray-form" class="space-y-3">
              <div>
                <label class="text-xs text-[#666] mb-1 block">Full Name *</label>
                <input type="text" name="name" required class="w-full border border-[#ccc] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2EAB5A] focus:border-transparent" />
              </div>
              <div>
                <label class="text-xs text-[#666] mb-1 block">Email *</label>
                <input type="email" name="email" required class="w-full border border-[#ccc] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2EAB5A] focus:border-transparent" />
              </div>
              <div>
                <label class="text-xs text-[#666] mb-1 block">Mobile *</label>
                <input type="tel" name="mobile" class="w-full border border-[#ccc] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2EAB5A] focus:border-transparent" />
              </div>
              <button type="submit" class="w-full bg-[#1D1C1C] text-white font-semibold text-sm rounded-lg py-2.5 hover:bg-[#333] transition-colors">Submit</button>
            </form>
          </div>
        </div>

        <!-- ── COLUMN 2: GIVE ──────────────────────────────── -->
        <div class="flex flex-col">
          <!-- Photo with orange badge -->
          <div class="relative mb-8">
            <img
              src="https://assets.spiritmediapublishing.com/images/ghi-img_2295-scaled.jpg"
              alt="Indian girl in field — donate to India missions and transform lives"
              width="600" height="450" loading="lazy"
              class="w-full aspect-[4/3] object-cover rounded-xl"
            />
            <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 w-12 h-12 rounded-full bg-[#FFA500] flex items-center justify-center shadow-lg">
              <span class="text-white font-bold text-xl">2</span>
            </div>
          </div>
          <h3 class="text-[#1D1C1C] font-bold text-2xl text-center mb-3">Give</h3>
          <p class="text-[#444] text-sm leading-relaxed text-center mb-6">God uses every gift through Global Hope India to make Christ known and extend God's kingdom in India. Your donation funds Bible distribution, supports Christian missionaries, sponsors orphan care, and advances the gospel among unreached people.</p>
          <div class="text-center">
            <a href="https://givebutter.com/global-hope-india" target="_blank" rel="noopener noreferrer" class="inline-block bg-[#1a2456] text-white font-semibold text-sm rounded-full px-8 py-3 hover:bg-[#111b40] transition-colors">Give to India Missions</a>
          </div>
        </div>

        <!-- ── COLUMN 3: GO ────────────────────────────────── -->
        <div class="flex flex-col">
          <!-- Photo with orange badge -->
          <div class="relative mb-8">
            <img
              src="https://assets.spiritmediapublishing.com/images/ghi-img_6300-scaled.jpg"
              alt="Mission team with children — short term mission trip India"
              width="600" height="450" loading="lazy"
              class="w-full aspect-[4/3] object-cover rounded-xl"
            />
            <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 w-12 h-12 rounded-full bg-[#FFA500] flex items-center justify-center shadow-lg">
              <span class="text-white font-bold text-xl">3</span>
            </div>
          </div>
          <h3 class="text-[#1D1C1C] font-bold text-2xl text-center mb-3">Go</h3>
          <p class="text-[#444] text-sm leading-relaxed text-center mb-6">God called every believer to go! Over 1,000 people have traveled on short term mission trips to India through Global Hope India. Teams go and empower Indian partners to advance the gospel, distribute Bibles, and transform lives in communities that have never heard the name of Jesus.</p>
          <!-- Go Form -->
          <div class="border border-[#e0e0e0] rounded-xl bg-[#fafafa] p-5 flex-1">
            <form id="go-form" class="space-y-3">
              <div>
                <label class="text-xs text-[#666] mb-1 block">Full Name *</label>
                <input type="text" name="name" required class="w-full border border-[#ccc] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2EAB5A] focus:border-transparent" />
              </div>
              <div>
                <label class="text-xs text-[#666] mb-1 block">Email *</label>
                <input type="email" name="email" required class="w-full border border-[#ccc] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2EAB5A] focus:border-transparent" />
              </div>
              <div>
                <label class="text-xs text-[#666] mb-1 block">Mobile *</label>
                <input type="tel" name="mobile" class="w-full border border-[#ccc] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2EAB5A] focus:border-transparent" />
              </div>
              <div>
                <label class="text-xs text-[#666] mb-1 block">When Can You Go? *</label>
                <input type="text" name="when" class="w-full border border-[#ccc] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2EAB5A] focus:border-transparent" />
              </div>
              <div>
                <label class="text-xs text-[#666] mb-1 block">Who will go with you?</label>
                <input type="text" name="who" class="w-full border border-[#ccc] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2EAB5A] focus:border-transparent" />
              </div>
              <div>
                <label class="text-xs text-[#666] mb-1 block">Share any specifics (location, focus, questions)</label>
                <textarea name="specifics" rows="3" class="w-full border border-[#ccc] rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#2EAB5A] focus:border-transparent resize-none"></textarea>
              </div>
              <button type="submit" class="w-full bg-[#1D1C1C] text-white font-semibold text-sm rounded-lg py-2.5 hover:bg-[#333] transition-colors">Submit</button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  // Hero parallax
  const heroEl = document.getElementById('hero-parallax');
  if (heroEl && window.matchMedia('(min-width: 768px)').matches) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          heroEl.style.transform = `translateY(${window.scrollY * -0.3}px)`;
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }
</script>
