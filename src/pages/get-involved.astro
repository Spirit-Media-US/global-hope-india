---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Get Involved — Global Hope India"
  description="Join Global Hope India: Give, Pray, and Support for a Brighter Future. Pray for India, give to fund projects, or go on a mission trip."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Get Involved — Global Hope India",
      "url": "https://globalhopeindia.org/get-involved",
      "description": "Join Global Hope India: Give, Pray, and Support for a Brighter Future.",
      "publisher": { "@type": "Organization", "name": "Global Hope India", "url": "https://globalhopeindia.org" }
    })}></script>
    <script src="https://mail.spiritmediaone.com/js/form_embed.js" defer></script>
  </Fragment>

  <!-- ── HERO ────────────────────────────────────────────── -->
  <section class="relative min-h-[60vh] lg:min-h-[75vh] overflow-hidden">
    <img
      src="/images/get-involved-hero.png"
      alt="Indian girl holding Indian flag"
      class="absolute inset-0 w-full h-full object-cover object-[center_20%]"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-white/80 via-white/40 to-transparent"></div>
    <div id="hero-parallax" class="absolute bottom-10 lg:bottom-16 left-0 right-0 z-10 container mx-auto px-6 lg:px-12 will-change-transform">
      <h1 class="max-w-lg font-bold text-[#1D1C1C] text-[28px] md:text-[36px] lg:text-[50px] leading-[1.2]">Join Global Hope India:<br/>Give, Pray, and Support<br/>for a Brighter Future</h1>
    </div>
  </section>

  <!-- ── THREE COLUMNS: PRAY / GIVE / GO ─────────────────── -->
  <section class="section bg-white">
    <div class="container mx-auto max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">

        <!-- ── COLUMN 1: PRAY ──────────────────────────────── -->
        <div class="flex flex-col">
          <!-- Photo with orange badge -->
          <div class="relative mb-8">
            <img
              src="https://assets.spiritmediapublishing.com/images/ghi-img_4700-scaled.jpg"
              alt="Indian children praying"
              class="w-full aspect-[4/3] object-cover rounded-xl"
            />
            <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 w-12 h-12 rounded-full bg-[#FFA500] flex items-center justify-center shadow-lg">
              <span class="text-white font-bold text-xl">1</span>
            </div>
          </div>
          <h3 class="text-[#1D1C1C] font-bold text-2xl text-center mb-3">Pray</h3>
          <p class="text-[#444] text-sm leading-relaxed text-center mb-6">Pray for India. God loves India. Jesus died for India. Pray for God to open the eyes and hearts of all people of India to see, experience, and love Jesus as the one true God.</p>
          <!-- Pray Form (GHL embed — Kevin: replace PRAY_FORM_ID with actual form ID from GHL) -->
          <div class="border border-[#e0e0e0] rounded-xl bg-[#fafafa] p-5 flex-1">
            <p class="text-[#1D1C1C] font-bold text-sm text-center mb-4">I will pray. Send me prayer points.</p>
            <iframe
              src="https://mail.spiritmediaone.com/widget/form/PRAY_FORM_ID"
              style="width:100%;min-height:350px;border:none;"
              id="inline-pray-form"
              data-layout="{'id':'INLINE'}"
              data-trigger-type="alwaysShow"
              data-activation-type="alwaysActivated"
              data-deactivation-type="neverDeactivate"
              data-form-name="GHI Prayer Request"
              data-height="350"
              data-layout-iframe-id="inline-pray-form"
              data-form-id="PRAY_FORM_ID"
              title="GHI Prayer Request"
            ></iframe>
          </div>
        </div>

        <!-- ── COLUMN 2: GIVE ──────────────────────────────── -->
        <div class="flex flex-col">
          <!-- Photo with orange badge -->
          <div class="relative mb-8">
            <img
              src="https://assets.spiritmediapublishing.com/images/ghi-img_2295-scaled.jpg"
              alt="Indian girl standing in field"
              class="w-full aspect-[4/3] object-cover rounded-xl"
            />
            <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 w-12 h-12 rounded-full bg-[#FFA500] flex items-center justify-center shadow-lg">
              <span class="text-white font-bold text-xl">2</span>
            </div>
          </div>
          <h3 class="text-[#1D1C1C] font-bold text-2xl text-center mb-3">Give</h3>
          <p class="text-[#444] text-sm leading-relaxed text-center mb-6">God uses every gift through Global Hope India to make Christ known and extend God's kingdom in India.</p>
          <div class="text-center">
            <a href="https://givebutter.com/global-hope-india" target="_blank" rel="noopener noreferrer" class="inline-block bg-[#1a2456] text-white font-semibold text-sm rounded-full px-8 py-3 hover:bg-[#111b40] transition-colors">Donate now</a>
          </div>
        </div>

        <!-- ── COLUMN 3: GO ────────────────────────────────── -->
        <div class="flex flex-col">
          <!-- Photo with orange badge -->
          <div class="relative mb-8">
            <img
              src="https://assets.spiritmediapublishing.com/images/ghi-img_6300-scaled.jpg"
              alt="Woman with children near brick wall"
              class="w-full aspect-[4/3] object-cover rounded-xl"
            />
            <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 w-12 h-12 rounded-full bg-[#FFA500] flex items-center justify-center shadow-lg">
              <span class="text-white font-bold text-xl">3</span>
            </div>
          </div>
          <h3 class="text-[#1D1C1C] font-bold text-2xl text-center mb-3">Go</h3>
          <p class="text-[#444] text-sm leading-relaxed text-center mb-6">God called every believer to go! Over 1,000 people have traveled to India through Global Hope India. Teams go and empower Indian partners to do what they couldn't otherwise do.</p>
          <!-- Go Form (GHL embed — Kevin: replace GO_FORM_ID with actual form ID from GHL) -->
          <div class="border border-[#e0e0e0] rounded-xl bg-[#fafafa] p-5 flex-1">
            <iframe
              src="https://mail.spiritmediaone.com/widget/form/GO_FORM_ID"
              style="width:100%;min-height:500px;border:none;"
              id="inline-go-form"
              data-layout="{'id':'INLINE'}"
              data-trigger-type="alwaysShow"
              data-activation-type="alwaysActivated"
              data-deactivation-type="neverDeactivate"
              data-form-name="GHI Mission Trip Interest"
              data-height="500"
              data-layout-iframe-id="inline-go-form"
              data-form-id="GO_FORM_ID"
              title="GHI Mission Trip Interest"
            ></iframe>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  // Hero parallax
  const heroEl = document.getElementById('hero-parallax');
  if (heroEl && window.matchMedia('(min-width: 768px)').matches) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          heroEl.style.transform = `translateY(${window.scrollY * -0.3}px)`;
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }
</script>
