---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity.ts';

// Fetch from Sanity with hardcoded fallbacks
let partners: any[] = [];
let projectLinks: any[] = [];
let accountability: string[] = [];
let practicalResources: string[] = [];

try {
  const donationLinks = await sanityClient.fetch(`
    *[_type == "donationLink"] | order(order asc) {
      name, category, "url": donateUrl
    }
  `);
  partners = donationLinks.filter((d: any) => d.category === 'partner');
  projectLinks = donationLinks.filter((d: any) => d.category === 'project');
} catch (e) { /* fallback below */ }

try {
  const accItems = await sanityClient.fetch(`
    *[_type == "accountabilityItem"] | order(order asc) { text }
  `);
  accountability = accItems.map((a: any) => a.text);
} catch (e) { /* fallback below */ }

try {
  const resItems = await sanityClient.fetch(`
    *[_type == "practicalResource"] | order(order asc) { label }
  `);
  practicalResources = resItems.map((r: any) => r.label);
} catch (e) { /* fallback below */ }

// Fetch FAQs for projects page
let projectFaqs: any[] = [];
try {
  projectFaqs = await sanityClient.fetch(`*[_type == "faqItem" && page == "projects"] | order(order asc) { question, answer }`);
} catch (e) {}

// Fallbacks
if (partners.length === 0) partners = [
  { name: 'Achu in Nagaland', url: 'https://givebutter.com/AchuInNagaland' },
  { name: 'Amit in Dehradun', url: 'https://givebutter.com/AmitInDehradun' },
  { name: 'Anil in Andhra Pradesh', url: 'https://givebutter.com/AnilinAndhraPradesh' },
  { name: 'Bernardshaw in Chennai', url: 'https://givebutter.com/ChennaiMinistry' },
  { name: 'DBM in Dimapur', url: 'https://givebutter.com/DBMinDimapur' },
  { name: 'Dr S in Hyderabad', url: 'https://givebutter.com/DrSHyderabad' },
  { name: 'Kasbe in Pune', url: 'https://givebutter.com/KasbeinPune' },
  { name: 'KEL in Palakollu', url: 'https://givebutter.com/KELinPalakollu' },
  { name: 'Manoj in Mumbai', url: 'https://givebutter.com/ManojinMumbai' },
  { name: 'Mayon in Manipur', url: 'https://givebutter.com/MayoninManipur' },
  { name: 'Raja in Hyderabad', url: 'https://givebutter.com/RajaInHyderabad' },
  { name: 'Sekhar in Vizag', url: 'https://givebutter.com/SekharInVizag' },
  { name: "The Shepherd's House", url: 'https://givebutter.com/TheShepherdsHouse' },
];
if (projectLinks.length === 0) projectLinks = [
  { name: 'Bibles', url: 'https://givebutter.com/BiblesForIndia' },
  { name: 'Business Development', url: 'https://givebutter.com/TheShepherdsHouse' },
  { name: 'Child Development', url: 'https://givebutter.com/GHIChildDevelopment' },
  { name: 'Church Planting', url: 'https://givebutter.com/GHIChurchPlanting' },
  { name: 'Leadership Development', url: 'https://givebutter.com/GHILeadershipDevelopment' },
  { name: 'Village Development', url: 'https://givebutter.com/GHIVillageDevelopment' },
  { name: 'North East Healthcare Fund', url: 'https://givebutter.com/NorthEastHealthcareFund' },
];
if (accountability.length === 0) accountability = [
  'Global Hope India is a federally recognized 501(c)3 nonprofit organization located in Morrisville, North Carolina. All gifts are tax-deductible to the full extent permitted by law.',
  'GHI is a member of multiple independent financial accountability programs.',
  'Our Board of Directors controls our annual budget including all staff salaries.',
  'No one compensated by GHI, including our founder/executive director, has a vote or family member on our Board of Directors.',
  'Our Board of Directors reviews all bank accounts and financial transactions monthly, performs an annual audit, and secures an annual independent financial statement from a Certified Public Accountant.',
  'God uses every gift to GHI to radically transform Americans and Indian Nationals through missions.',
  '100% of every dollar given directly benefits our programs here in the USA and in India.',
];
if (practicalResources.length === 0) practicalResources = [
  'Clean Water Projects',
  'Hygiene Kits',
  'Motor bikes for leaders',
  'Church buildings',
  'Baptisteries',
  'Disaster Relief',
];
---

<Layout
  title="Give to Church Planting, Bibles & Orphan Care | GHI"
  description="Donate to India missions: fund Bible distribution, give to church planting, support orphans, and sponsor missionaries transforming lives across India today."
  ogImage="https://assets.spiritmediapublishing.com/images/ghi-projects-hero.png"
  keywords="give to church planting India, Bibles for India, fund Bible distribution India, support orphans in India, donate to India missions, sponsor child India Christian, support Christian missionaries India, building orphanages in India, transforming lives in India"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Projects — Global Hope India",
      "url": "https://globalhopeindia.org/projects",
      "description": "Donate to India missions: fund Bible distribution, give to church planting, support orphans, and sponsor Christian missionaries transforming lives across India.",
      "publisher": { "@type": "Organization", "name": "Global Hope India", "url": "https://globalhopeindia.org" }
    })}></script>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Where does my money go when I donate to Global Hope India?",
          "acceptedAnswer": { "@type": "Answer", "text": "Your donation funds Bible distribution, church planter support, orphan care, clean water projects, hygiene kits, and community development across India. Over 85% of every dollar given directly benefits programs in India and the USA." }
        },
        {
          "@type": "Question",
          "name": "Can I choose which project to fund?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. You can direct your gift to a specific partner or project such as Bibles for India, orphan care, church planting, or village development. Visit our Projects page to see all available giving options." }
        },
        {
          "@type": "Question",
          "name": "Is my donation to Global Hope India tax deductible?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Global Hope India is a federally recognized 501(c)(3) nonprofit organization located in Raleigh, North Carolina. All gifts are tax-deductible. You will receive a donation receipt for your records." }
        }
      ]
    })}></script>
  </Fragment>

  <!-- ── HERO + INTRO ─────────────────────────────────────── -->
  <section class="relative">
    <!-- Image area -->
    <div class="relative min-h-[55vh] lg:min-h-[65vh] overflow-hidden">
      <img
        src="https://assets.spiritmediapublishing.com/images/ghi-projects-hero.png"
        alt="Children playing on swings in India at sunset"
        width="1600" height="900" fetchpriority="high"
        class="absolute inset-0 w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
      <!-- Red box: heading at bottom-left of image -->
      <div id="hero-parallax" class="absolute bottom-6 left-0 right-0 z-10 container mx-auto px-6 lg:px-12 will-change-transform">
        <h1 style="color: white !important;" class="max-w-3xl font-bold text-[26px] md:text-[30px] lg:text-[50px] leading-[1.3] lg:leading-[1.2] drop-shadow-lg">Church Project:<br/>Building Faith & Community</h1>
      </div>
    </div>
    <!-- Blue box: intro text in white strip below image -->
    <div class="bg-white px-6 lg:px-12 py-8 lg:py-10">
      <div class="container mx-auto max-w-4xl">
        <p class="text-[#444] text-base lg:text-lg leading-relaxed">We share Jesus by funding projects that make Christ known and extend God's kingdom in India. Your generosity is needed and greatly appreciated. God uses every gift to accomplish His mission in India.</p>
        <p class="text-[#444] text-base lg:text-lg leading-relaxed mt-4">Please prayerfully consider sponsoring these projects:</p>
      </div>
    </div>
  </section>

  <!-- ── THREE PROJECT CARDS ─────────────────────────────── -->
  <section class="section-sm bg-[#F8F5EF]">
    <div class="container mx-auto max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Bibles for India -->
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-5 flex items-center justify-center text-[#1d803f]">
            <svg class="w-12 h-12" viewBox="0 0 448 512" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M448 358.4V25.6c0-16-9.6-25.6-25.6-25.6H96C41.6 0 0 41.6 0 96v320c0 54.4 41.6 96 96 96h326.4c12.8 0 25.6-9.6 25.6-25.6v-16c0-6.4-3.2-12.8-9.6-19.2-3.2-16-3.2-60.8 0-73.6 6.4-3.2 9.6-9.6 9.6-19.2zM144 144c0-8.84 7.16-16 16-16h48V80c0-8.84 7.16-16 16-16h32c8.84 0 16 7.16 16 16v48h48c8.84 0 16 7.16 16 16v32c0 8.84-7.16 16-16 16h-48v112c0 8.84-7.16 16-16 16h-32c-8.84 0-16-7.16-16-16V192h-48c-8.84 0-16-7.16-16-16v-32zm236.8 304H96c-19.2 0-32-12.8-32-32s16-32 32-32h284.8v64z"/></svg>
          </div>
          <h2 class="text-[#1D1C1C] font-bold text-[22px] md:text-[24px] mb-3">Bibles for India</h2>
          <p class="text-[#444] leading-relaxed">1.4B people call India home. 1B people in India have never held a Bible. Contribute now to share Bibles in India: <a href="https://givebutter.com/BiblesForIndia" target="_blank" rel="noopener noreferrer" class="font-bold text-[#1D1C1C] hover:text-[#1d803f] transition-colors underline">Bibles</a></p>
        </div>

        <!-- Orphan Care -->
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-5 flex items-center justify-center text-[#1d803f]">
            <svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" fill="currentColor"/></svg>
          </div>
          <h2 class="text-[#1D1C1C] font-bold text-[22px] md:text-[24px] mb-3">Orphan Care</h2>
          <p class="text-[#444] leading-relaxed">India is home to half of the world's orphans. Contribute now to sponsor orphan care in India: <a href="https://givebutter.com/GHIChildDevelopment" target="_blank" rel="noopener noreferrer" class="font-bold text-[#1D1C1C] hover:text-[#1d803f] transition-colors underline">Child Development</a></p>
        </div>

        <!-- Community Development -->
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-5 flex items-center justify-center text-[#1d803f]">
            <svg class="w-12 h-12" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          </div>
          <h2 class="text-[#1D1C1C] font-bold text-[22px] md:text-[24px] mb-3">Community Development</h2>
          <p class="text-[#444] leading-relaxed">We're transforming whole communities through building strong churches and business leaders for Christ: <a href="https://givebutter.com/GHIVillageDevelopment" target="_blank" rel="noopener noreferrer" class="font-bold text-[#1D1C1C] hover:text-[#1d803f] transition-colors underline">Community Development</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PRACTICAL RESOURCES ─────────────────────────────── -->
  <section class="section bg-white">
    <div class="container mx-auto max-w-4xl">
      <h2 class="text-[#1D1C1C] font-bold text-[26px] md:text-[30px] lg:text-[50px] leading-tight mb-8">Practical Resources</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-4 mb-6">
        {practicalResources.map(item => (
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-[#1d803f] shrink-0" viewBox="0 0 512 512" fill="currentColor"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
            <span class="text-[#444] text-lg">{item}</span>
          </div>
        ))}
      </div>
      <p class="text-[#444] text-lg leading-relaxed mb-8">Everything to proclaim and demonstrate Jesus' love.</p>
      <a href="https://givebutter.com/global-hope-india" target="_blank" rel="noopener noreferrer" class="btn btn-green">Fund This Project</a>
    </div>
  </section>

  <!-- ── FAQ / TOGGLES ───────────────────────────────────── -->
  <section class="section bg-[#f9f9f9]">
    <div class="container mx-auto max-w-4xl">
      <div class="space-y-4">
        <!-- Partners Toggle -->
        <div class="accordion-card bg-white rounded-xl border border-[#e0e0e0]">
          <button class="accordion-btn w-full flex items-center justify-between text-left p-6" aria-expanded="false">
            <h3 class="text-lg font-bold text-[#1D1C1C]">GHI Partners in India</h3>
            <span class="accordion-sign text-[#1d803f] text-2xl leading-none shrink-0 ml-4">+</span>
          </button>
          <div class="accordion-body px-6 pb-6 hidden">
            <p class="text-[#444] mb-4">Please click the Partner you wish to support:</p>
            <ul class="space-y-2 mb-6">
              {partners.map(p => (
                <li>
                  <a href={p.url} target="_blank" rel="noopener noreferrer" class="font-bold text-[#1D1C1C] hover:text-[#1d803f] transition-colors">{p.name}</a>
                </li>
              ))}
            </ul>
            <p class="text-[#444] mb-4">Please click the project you wish to support:</p>
            <ul class="space-y-2">
              {projectLinks.map(p => (
                <li>
                  <a href={p.url} target="_blank" rel="noopener noreferrer" class="font-bold text-[#1D1C1C] hover:text-[#1d803f] transition-colors">{p.name}</a>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Financial Accountability Toggle -->
        <div class="accordion-card bg-white rounded-xl border border-[#e0e0e0]">
          <button class="accordion-btn w-full flex items-center justify-between text-left p-6" aria-expanded="false">
            <h3 class="text-lg font-bold text-[#1D1C1C]">Financial Accountability</h3>
            <span class="accordion-sign text-[#1d803f] text-2xl leading-none shrink-0 ml-4">+</span>
          </button>
          <div class="accordion-body px-6 pb-6 hidden">
            <p class="text-[#444] mb-4">Here are 7 things every donor should know about GHI:</p>
            <ol class="list-decimal list-outside pl-5 space-y-3 text-[#444] leading-relaxed marker:text-[#1d803f] marker:font-bold">
              {accountability.map(item => (
                <li>{item}</li>
              ))}
            </ol>
          </div>
        </div>

        {projectFaqs.map((faq: any) => (
          <div class="accordion-card bg-white rounded-xl border border-[#e0e0e0]">
            <button class="accordion-btn w-full flex items-center justify-between text-left p-6" aria-expanded="false">
              <h3 class="text-lg font-bold text-[#1D1C1C]">{faq.question}</h3>
              <span class="accordion-sign text-[#1d803f] text-2xl leading-none shrink-0 ml-4">+</span>
            </button>
            <div class="accordion-body px-6 pb-6 hidden">
              <p class="text-[#444] leading-relaxed">{faq.answer}</p>
            </div>
          </div>
        ))}

        <!-- Privacy Toggle (always shown) -->
        <div class="accordion-card bg-white rounded-xl border border-[#e0e0e0]">
          <button class="accordion-btn w-full flex items-center justify-between text-left p-6" aria-expanded="false">
            <h3 class="text-lg font-bold text-[#1D1C1C]">GHI's privacy policy</h3>
            <span class="accordion-sign text-[#1d803f] text-2xl leading-none shrink-0 ml-4">+</span>
          </button>
          <div class="accordion-body px-6 pb-6 hidden">
            <p class="text-[#444] leading-relaxed">GHI protects your privacy! Under no circumstance does GHI ever sell or give out our contact lists. <a href="/privacy-policy" class="font-bold text-[#1D1C1C] hover:text-[#1d803f] transition-colors underline">See our Privacy Policy.</a></p>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  document.querySelectorAll('.accordion-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const card = btn.closest('.accordion-card');
      const body = card.querySelector('.accordion-body');
      const sign = btn.querySelector('.accordion-sign');
      const isOpen = !body.classList.contains('hidden');

      if (isOpen) {
        body.classList.add('hidden');
        sign.textContent = '+';
        btn.setAttribute('aria-expanded', 'false');
      } else {
        body.classList.remove('hidden');
        sign.textContent = '—';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Parallax: heading drifts up as user scrolls
  const heroEl = document.getElementById('hero-parallax');
  if (heroEl && window.matchMedia('(min-width: 768px)').matches) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          heroEl.style.transform = `translateY(${window.scrollY * -0.3}px)`;
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }
</script>
