---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    icon: '📖',
    title: 'Bibles for India',
    desc: '1 billion people in India have never held a Bible. We distribute God\'s Word across the nation so every person can know His story.',
    cta: 'Give Bibles',
    color: '#FEC415',
  },
  {
    icon: '👶',
    title: 'Orphan Care',
    desc: 'India is home to half of the world\'s orphans. We sponsor orphan care and child development programs through local churches.',
    cta: 'Sponsor a Child',
    color: '#2EAB5A',
  },
  {
    icon: '🏘️',
    title: 'Village Development',
    desc: 'Transforming whole communities by building strong churches and business leaders for Christ across rural India.',
    cta: 'Transform a Village',
    color: '#FEC415',
  },
  {
    icon: '💧',
    title: 'Clean Water Projects',
    desc: 'We partner with local churches to bring safe drinking water to communities in need across India.',
    cta: 'Fund a Water Project',
    color: '#2EAB5A',
  },
  {
    icon: '🧴',
    title: 'Hygiene Kits',
    desc: 'Practical hygiene resources distributed through local churches — meeting physical needs as a gateway to the gospel.',
    cta: 'Send Hygiene Kits',
    color: '#FEC415',
  },
  {
    icon: '📚',
    title: 'Leadership Development',
    desc: 'Training church planters, pastors, worship leaders, and core leaders with biblical truth and practical ministry resources.',
    cta: 'Train a Leader',
    color: '#2EAB5A',
  },
  {
    icon: '⛪',
    title: 'Church Planting',
    desc: 'Directly funding the establishment of new congregations across every region of India — north, south, east, west, and northeast.',
    cta: 'Plant a Church',
    color: '#FEC415',
  },
  {
    icon: '🏥',
    title: 'Northeast Healthcare Fund',
    desc: 'A dedicated fund bringing healthcare access to underserved communities across Northeast India.',
    cta: 'Give to Healthcare',
    color: '#2EAB5A',
  },
  {
    icon: '💼',
    title: 'Business Development',
    desc: 'Supporting "The Shepherd\'s House" and other entrepreneurship initiatives that create sustainable livelihoods for believers.',
    cta: 'Support Business',
    color: '#FEC415',
  },
];
---

<Layout
  title="Projects — Global Hope India"
  description="Explore Global Hope India's projects: Bibles, orphan care, clean water, leadership development, church planting, and more. Sharing Jesus by funding what matters."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "Projects — Global Hope India",
      "url": "https://globalhopeindia.org/projects",
      "description": "Explore Global Hope India's projects: Bibles, orphan care, clean water, leadership development, church planting, and more.",
      "publisher": { "@type": "Organization", "name": "Global Hope India", "url": "https://globalhopeindia.org" }
    })}></script>
  </Fragment>

  <!-- ── PAGE HERO ────────────────────────────────────────── -->
  <section class="bg-[#1D1C1C] text-white pt-36 pb-20 px-6">
    <div class="container mx-auto text-center">
      <span class="eyebrow">How We Serve</span>
      <h1 class="text-white mb-5">Sharing Jesus by Funding Projects That Make Christ Known</h1>
      <p class="text-white/70 text-lg max-w-2xl mx-auto">
        Every project is carried out through local Indian churches — empowering God's people to meet both spiritual and physical needs.
      </p>
    </div>
  </section>

  <!-- ── PROJECTS GRID ────────────────────────────────────── -->
  <section class="section bg-white">
    <div class="container mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map(p => (
          <div class="rounded-2xl border-2 border-[#e0e0e0] hover:border-[#FEC415] transition-all p-8 flex flex-col">
            <div class="text-5xl mb-4">{p.icon}</div>
            <h3 class="mb-3">{p.title}</h3>
            <p class="text-[#666] leading-relaxed flex-grow mb-6">{p.desc}</p>
            <a
              href="https://givebutter.com/GlobalHopeIndia"
              target="_blank"
              rel="noopener noreferrer"
              class="btn text-sm text-center"
              style={`background-color: ${p.color}; border-color: ${p.color};`}
            >
              {p.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PARTNERS ──────────────────────────────────────────── -->
  <section class="section bg-[#f5f5f5]">
    <div class="container mx-auto max-w-3xl text-center">
      <span class="eyebrow">Our Network</span>
      <h2 class="mb-6">Partner Churches Across India</h2>
      <p class="text-[#444] text-lg leading-relaxed mb-8">
        Global Hope India works with 13+ long-term indigenous church-planting partners across India — in Nagaland, Dehradun, Andhra Pradesh, Chennai, Mumbai, Hyderabad, Manipur, and beyond.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm text-[#666] mb-10">
        {['Nagaland', 'Dehradun', 'Andhra Pradesh', 'Chennai', 'Mumbai', 'Hyderabad', 'Manipur', 'Northeast India'].map(region => (
          <div class="bg-white rounded-lg px-4 py-3 font-medium border border-[#e0e0e0]">{region}</div>
        ))}
      </div>
      <a href="https://givebutter.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" class="btn">Support Our Partners</a>
    </div>
  </section>

  <!-- ── FINANCIAL ACCOUNTABILITY ─────────────────────────── -->
  <section class="section bg-[#1D1C1C] text-white">
    <div class="container mx-auto text-center">
      <span class="eyebrow">Transparency</span>
      <h2 class="text-white mb-8">Faithful Stewardship of Every Gift</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-4xl mx-auto">
        {[
          { icon: '📊', text: 'Monthly board review of all accounts and transactions' },
          { icon: '🔍', text: 'Annual independent audits by CPAs' },
          { icon: '💼', text: 'Board controls all compensation decisions' },
          { icon: '💯', text: '100% of donations benefit programs' },
        ].map(item => (
          <div class="bg-white/10 rounded-xl p-6">
            <div class="text-3xl mb-3">{item.icon}</div>
            <p class="text-white/80 text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────────────── -->
  <section class="section bg-[#FEC415]">
    <div class="container mx-auto text-center">
      <h2 class="text-[#1D1C1C] mb-4">Every Dollar Makes a Difference</h2>
      <p class="text-[#1D1C1C]/80 text-lg max-w-xl mx-auto mb-8">Choose a project that moves your heart — or give to where the need is greatest.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://givebutter.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" class="btn" style="background-color: #1D1C1C; color: #FEC415; border-color: #1D1C1C;">Donate Now</a>
        <a href="/get-involved" class="btn" style="background-color: transparent; color: #1D1C1C; border-color: #1D1C1C;">Other Ways to Help</a>
      </div>
    </div>
  </section>
</Layout>
