export async function getStaticPaths() {
  let sanityPaths: any[] = [];
  try {
    const posts = await sanityClient.fetch(`*[_type == "blogPost"] { "slug": slug.current }`);
    sanityPaths = posts.map((p: any) => ({ params: { slug: p.slug } }));
  } catch (e) {}
  const staticSlugs = [
    'our-partners-in-india',
    'support-key-projects-in-manipur',
    'medical-camp-miracles-healing-bodies-and-souls',
    'hope-for-indias-special-needs',
    'empowering-the-deaf-community-the-mission-of-dbm-in-nagaland-india',
    'elim-school-supporting-pastor-mayons-mission-in-manipur',
  ];
  const staticPaths = staticSlugs.map(s => ({ params: { slug: s } }));
  return [...sanityPaths, ...staticPaths];
}

const { slug } = Astro.params;

let post: any = null;
let related: any[] = [];
let isStatic = false;
try {
  post = await sanityClient.fetch(
    `*[_type == "blogPost" && slug.current == $slug][0]`,
    { slug }
  );
  if (post?.tags?.length) {
    related = await sanityClient.fetch(
      `*[_type == "blogPost" && slug.current != $slug && count((tags)[@ in $tags]) > 0] | order(publishDate desc) [0..2] {
        title, "slug": slug.current, excerpt, publishDate, "imageUrl": heroImage.asset->url, tags
      }`,
      { slug, tags: post.tags }
    );
  }
} catch (e) {}

// Use static post if available (always wins over Sanity for known static slugs)
if (staticPosts[slug]) {
  isStatic = true;
  const sp = staticPosts[slug];
  post = {
    title: sp.title,
    excerpt: sp.excerpt,
    author: sp.author,
    publishDate: sp.publishDate,
    tags: sp.tags,
    heroImage: null,
    body: null,
    seoTitle: null,
    seoDescription: null,
  };
} else if (!post) {
  // No Sanity post and no static post
}

if (!post) return Astro.redirect('/blog');

function renderPortableText(blocks: any[]): string {
  if (!Array.isArray(blocks)) return '';
  return blocks.map((block: any) => {
    if (!block || block._type !== 'block') return '';
    const children = Array.isArray(block.children) ? block.children : [];
    const text = children.map((child: any) => {
      if (!child) return '';
      let t = child.text || '';
      const marks = Array.isArray(child.marks) ? child.marks : [];
      if (marks.includes('strong')) t = `<strong>${t}</strong>`;
      if (marks.includes('em')) t = `<em>${t}</em>`;
      const linkMark = marks.find((m: any) => m && typeof m === 'object' && m._type === 'link');
      if (linkMark?.href) t = `<a href="${linkMark.href}" class="text-[#2EAB5A] hover:underline" target="_blank" rel="noopener noreferrer">${t}</a>`;
      return t;
    }).join('');
    const style = block.style || 'normal';
    if (style === 'h2') return `<h2 class="text-2xl font-bold mt-10 mb-4">${text}</h2>`;
    if (style === 'h3') return `<h3 class="text-xl font-bold mt-8 mb-3">${text}</h3>`;
    return `<p class="text-[#444] leading-relaxed mb-5">${text}</p>`;
  }).join('');
}

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const formatDate = (d: string) => {
  const dt = new Date(d);
  return `${MONTHS[dt.getUTCMonth()]} ${dt.getUTCDate()}, ${dt.getUTCFullYear()}`;
};

const heroImage = isStatic
  ? staticPosts[slug].heroImageUrl
  : post.heroImage
    ? urlFor(post.heroImage).width(1200).format('webp').url()
    : null;
const author = post.author || 'Global Hope India';
const tags = post.tags || [];
const bodyHtml = isStatic ? staticPosts[slug].bodyHtml : renderPortableText(post.body);
const publishDate = post.publishDate ? formatDate(post.publishDate) : '';
const postUrl = `https://globalhopeindia.org/blog/${slug}`;
const encodedUrl = encodeURIComponent(postUrl);
const encodedTitle = encodeURIComponent(post.title);
