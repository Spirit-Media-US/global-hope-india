---
import Layout from '../../layouts/Layout.astro';
import { sanityClient, urlFor } from '../../lib/sanity.ts';

// Static fallback posts (not in Sanity yet)
const staticPosts: Record<string, any> = {
  'our-partners-in-india': {
    title: 'Our Partners in India',
    excerpt: 'Global Hope India works with indigenous church-planting partners across India.',
    author: 'Global Hope India',
    publishDate: '2025-03-18',
    tags: ['Partners', 'South India'],
    heroImageUrl: 'https://globalhopeindia.org/wp-content/uploads/2025/03/GHI-Blog-3-03.18.25.webp',
    bodyHtml: `
      <p>In Chennai, a major city in India, a local church has found itself at a crossroads, facing significant challenges in continuing to meet for worship. The church, which has been gathering in a space located on the first floor of a home, is currently in a difficult situation due to stringent local regulations that do not allow churches to meet in residential spaces or adjacent properties. This regulation has been an ongoing issue, and recently, the church faces a new challenge.</p>
      <h2>Challenges in Chennai Church</h2>
      <p>For the church in Chennai, during the first service of the year, on January 1, 2025, a group of individuals entered the church service, disrupting worship. This incident, along with previous warnings from local authorities, has left the congregation in a state of uncertainty. They were given just two weeks to vacate their current location and find an alternative space for worship which now puts them in a very tight situation, needing prayers and help.</p>
      <h2>The Urgent Need for a New House of Worship</h2>
      <p>The church, which relies heavily on the support of its local community and believers, now faces an urgent need to secure a new space. The plan is to find land for rent or lease where they can establish a temporary shelter made of sheets until a more permanent solution can be found. However, with limited resources, they are in dire need of financial support to cover the costs of securing land and setting up a safe and suitable place for worship.</p>
      <p>In the midst of these challenges, they are calling on the global Christian community to join them in prayer. They ask for prayer that God will provide them with a new place to gather, a place where they can worship freely without fear of interference or disruption.</p>
      <h2>Your Prayer is Needed</h2>
      <p>In times like these, the power of prayer and the support of the global church are vital. As the church in Chennai navigates this challenging season, Global Hope India asks for prayers that God will open doors for them to find a suitable and permanent place of worship. Additionally, the church is seeking financial support to cover the costs of securing land and establishing a temporary space.</p>
      <p>The road ahead may be uncertain, but with the support of prayer and the generosity of believers around the world, we trust that God will provide. Please join us in praying for the church in Chennai, as well as for other congregations across India who are facing similar struggles. Pray that they will be able to worship freely and boldly, without fear or hindrance.</p>
      <p>To support the church in Chennai, please donate here: <a href="https://givebutter.com/ChennaiMinistry" target="_blank" rel="noopener noreferrer" class="text-[#2EAB5A] hover:underline font-semibold">https://givebutter.com/ChennaiMinistry</a></p>
      <p>Let's stand together in prayer and support, trusting that God will provide for His followers in this challenging time.</p>
      <h2>How You Can Help</h2>
      <p><strong>Pray for India:</strong> Join us in praying for the children and the mission.</p>
      <p><strong>Give and Go:</strong> Consider supporting financially or volunteering to make a direct impact.</p>
      <p><strong>Share the Vision:</strong> Spread the word among your friends, family, and church. Your advocacy can bring more support to this cause.</p>
      <p>Together, we can support the vision of making education accessible to all children. Let's show them the love of Jesus by ensuring they have the opportunity to learn and grow.</p>
      <p>You too can create an impact in the lives of these children and elders by sending your donation <a href="https://givebutter.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" class="text-[#2EAB5A] hover:underline font-semibold">here</a>. If you'd prefer to give by check, please make it payable to and mail it to:</p>
      <p>Global Hope India<br/>8045 Arco Corporate Drive STE 130<br/>Raleigh, NC 27617</p>
      <p>Thank you for your continued prayers and support. We couldn't do this without you.</p>
    `,
  },
};

export async function getStaticPaths() {
  let sanityPaths: any[] = [];
  try {
    const posts = await sanityClient.fetch(`*[_type == "blogPost"] { "slug": slug.current }`);
    sanityPaths = posts.map((p: any) => ({ params: { slug: p.slug } }));
  } catch (e) {}
  const staticSlugs = ['our-partners-in-india'];
  const staticPaths = staticSlugs.map(s => ({ params: { slug: s } }));
  return [...sanityPaths, ...staticPaths];
}

const { slug } = Astro.params;

let post: any = null;
let related: any[] = [];
let isStatic = false;
try {
  post = await sanityClient.fetch(
    `*[_type == "blogPost" && slug.current == $slug][0]`,
    { slug }
  );
  if (post?.tags?.length) {
    related = await sanityClient.fetch(
      `*[_type == "blogPost" && slug.current != $slug && count((tags)[@ in $tags]) > 0] | order(publishDate desc) [0..2] {
        title, "slug": slug.current, excerpt, publishDate, "imageUrl": heroImage.asset->url, tags
      }`,
      { slug, tags: post.tags }
    );
  }
} catch (e) {}

// Use static post if available (always wins over Sanity for known static slugs)
if (staticPosts[slug]) {
  isStatic = true;
  const sp = staticPosts[slug];
  post = {
    title: sp.title,
    excerpt: sp.excerpt,
    author: sp.author,
    publishDate: sp.publishDate,
    tags: sp.tags,
    heroImage: null,
    body: null,
    seoTitle: null,
    seoDescription: null,
  };
} else if (!post) {
  // No Sanity post and no static post
}

if (!post) return Astro.redirect('/blog');

function renderPortableText(blocks: any[]): string {
  if (!Array.isArray(blocks)) return '';
  return blocks.map((block: any) => {
    if (!block || block._type !== 'block') return '';
    const children = Array.isArray(block.children) ? block.children : [];
    const text = children.map((child: any) => {
      if (!child) return '';
      let t = child.text || '';
      const marks = Array.isArray(child.marks) ? child.marks : [];
      if (marks.includes('strong')) t = `<strong>${t}</strong>`;
      if (marks.includes('em')) t = `<em>${t}</em>`;
      const linkMark = marks.find((m: any) => m && typeof m === 'object' && m._type === 'link');
      if (linkMark?.href) t = `<a href="${linkMark.href}" class="text-[#2EAB5A] hover:underline" target="_blank" rel="noopener noreferrer">${t}</a>`;
      return t;
    }).join('');
    const style = block.style || 'normal';
    if (style === 'h2') return `<h2 class="text-2xl font-bold mt-10 mb-4">${text}</h2>`;
    if (style === 'h3') return `<h3 class="text-xl font-bold mt-8 mb-3">${text}</h3>`;
    return `<p class="text-[#444] leading-relaxed mb-5">${text}</p>`;
  }).join('');
}

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const formatDate = (d: string) => {
  const dt = new Date(d);
  return `${MONTHS[dt.getUTCMonth()]} ${dt.getUTCDate()}, ${dt.getUTCFullYear()}`;
};

const heroImage = isStatic
  ? staticPosts[slug].heroImageUrl
  : post.heroImage
    ? urlFor(post.heroImage).width(1200).format('webp').url()
    : null;
const author = post.author || 'Global Hope India';
const tags = post.tags || [];
const bodyHtml = isStatic ? staticPosts[slug].bodyHtml : renderPortableText(post.body);
const publishDate = post.publishDate ? formatDate(post.publishDate) : '';
const postUrl = `https://globalhopeindia.org/blog/${slug}`;
const encodedUrl = encodeURIComponent(postUrl);
const encodedTitle = encodeURIComponent(post.title);
---

<Layout
  title={post.seoTitle || `${post.title} | GHI Magazine`}
  description={post.seoDescription || post.excerpt || 'Read this story on the Global Hope India blog.'}
  ogImage={heroImage}
>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="article" />
    <meta property="article:author" content={author} />
    <meta property="article:published_time" content={post.publishDate} />
    {tags.length > 0 && <meta property="article:section" content={tags[0]} />}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.title,
      "description": post.excerpt || post.title,
      "image": heroImage,
      "author": { "@type": "Organization", "name": "Global Hope India" },
      "publisher": { "@type": "Organization", "name": "Global Hope India", "url": "https://globalhopeindia.org" },
      "url": postUrl,
      "datePublished": post.publishDate
    })}></script>
  </Fragment>

  <!-- ── SOCIAL SHARE ICONS (top) ────────────────────────────── -->
  <section class="bg-white pt-24 pb-4 px-6">
    <div class="container mx-auto max-w-3xl">
      <div class="flex items-center gap-3">
        <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook" class="w-8 h-8 rounded-full bg-[#1D1C1C] flex items-center justify-center hover:bg-[#2EAB5A] transition-colors">
          <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
        </a>
        <a href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`} target="_blank" rel="noopener noreferrer" aria-label="Share on X" class="w-8 h-8 rounded-full bg-[#1D1C1C] flex items-center justify-center hover:bg-[#2EAB5A] transition-colors">
          <svg class="w-4 h-4 text-white" viewBox="0 0 300 300" fill="currentColor"><path d="M178.57 127.15 290.27 0h-26.46l-97.03 110.38L89.34 0H0l117.13 166.93L0 300h26.46l102.4-116.59L194.66 300H284L178.57 127.15zm-36.26 41.26-11.87-16.61L36.16 19.54h40.68l76.17 106.66 11.87 16.61 99.05 138.65h-40.69l-80.93-113.25z"/></svg>
        </a>
        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn" class="w-8 h-8 rounded-full bg-[#1D1C1C] flex items-center justify-center hover:bg-[#2EAB5A] transition-colors">
          <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href={`https://api.whatsapp.com/send?text=${encodedTitle}%20${encodedUrl}`} target="_blank" rel="noopener noreferrer" aria-label="Share on WhatsApp" class="w-8 h-8 rounded-full bg-[#1D1C1C] flex items-center justify-center hover:bg-[#2EAB5A] transition-colors">
          <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
        <a href={`https://pinterest.com/pin/create/button/?url=${encodedUrl}&description=${encodedTitle}`} target="_blank" rel="noopener noreferrer" aria-label="Share on Pinterest" class="w-8 h-8 rounded-full bg-[#1D1C1C] flex items-center justify-center hover:bg-[#2EAB5A] transition-colors">
          <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
        </a>
        <a href={`mailto:?subject=${encodedTitle}&body=${encodedUrl}`} aria-label="Share via Email" class="w-8 h-8 rounded-full bg-[#1D1C1C] flex items-center justify-center hover:bg-[#2EAB5A] transition-colors">
          <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── HERO IMAGE COLLAGE ────────────────────────────────── -->
  <section class="bg-white px-6 py-8">
    <div class="container mx-auto max-w-3xl">
      {heroImage ? (
        <div class="relative flex items-center justify-center h-[280px] lg:h-[350px]">
          <!-- Green circle outlines -->
          <div class="absolute w-[220px] h-[220px] lg:w-[280px] lg:h-[280px] rounded-full border-[6px] border-[#2EAB5A] left-[5%] lg:left-[8%] top-[10%]"></div>
          <div class="absolute w-[200px] h-[200px] lg:w-[260px] lg:h-[260px] rounded-full border-[6px] border-[#2EAB5A] right-[5%] lg:right-[8%] top-[5%]"></div>
          <!-- Photo circles -->
          <div class="absolute w-[180px] h-[180px] lg:w-[240px] lg:h-[240px] rounded-full overflow-hidden left-[8%] lg:left-[10%] top-[15%] z-10 shadow-lg">
            <img src={heroImage} alt={post.title} class="w-full h-full object-cover object-left" />
          </div>
          <div class="absolute w-[180px] h-[180px] lg:w-[240px] lg:h-[240px] rounded-full overflow-hidden right-[8%] lg:right-[10%] top-[8%] z-20 shadow-lg">
            <img src={heroImage} alt={post.title} class="w-full h-full object-cover object-[80%_center]" />
          </div>
        </div>
      ) : null}
    </div>
  </section>

  <!-- ── POST HEADER ───────────────────────────────────────── -->
  <section class="bg-white px-6 pb-8">
    <div class="container mx-auto max-w-3xl text-center">
      <h1 class="mb-3">{post.title}</h1>
      <p class="text-[#2EAB5A] text-sm font-medium">{publishDate}</p>
    </div>
  </section>

  <!-- ── CONTENT ───────────────────────────────────────────── -->
  <section class="bg-white px-6 py-12">
    <div class="container mx-auto max-w-3xl">
      <div set:html={bodyHtml} />
    </div>
  </section>

  <!-- ── SHARE BAR ─────────────────────────────────────────── -->
  <section class="bg-[#f5f5f5] px-6 py-10 border-t border-[#e0e0e0]">
    <div class="container mx-auto max-w-3xl">
      <div class="flex items-center gap-4 flex-wrap">
        <span class="text-xs font-semibold text-[#888] uppercase tracking-widest shrink-0">Share this story</span>
        <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-[#e0e0e0] bg-white px-4 py-2 text-sm font-semibold text-[#555] hover:bg-[#f5f5f5] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-[#1877F2]"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
          Facebook
        </a>
        <a href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-[#e0e0e0] bg-white px-4 py-2 text-sm font-semibold text-[#555] hover:bg-[#f5f5f5] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 300 300" fill="currentColor"><path d="M178.57 127.15 290.27 0h-26.46l-97.03 110.38L89.34 0H0l117.13 166.93L0 300h26.46l102.4-116.59L194.66 300H284L178.57 127.15zm-36.26 41.26-11.87-16.61L36.16 19.54h40.68l76.17 106.66 11.87 16.61 99.05 138.65h-40.69l-80.93-113.25z"/></svg>
          X
        </a>
        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-[#e0e0e0] bg-white px-4 py-2 text-sm font-semibold text-[#555] hover:bg-[#f5f5f5] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-[#0A66C2]"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <button id="copy-btn" data-url={postUrl} class="inline-flex items-center gap-2 rounded-lg border border-[#e0e0e0] bg-white px-4 py-2 text-sm font-semibold text-[#555] hover:bg-[#f5f5f5] transition-colors cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          <span id="copy-label">Copy link</span>
        </button>
      </div>
    </div>
  </section>

  <!-- ── LEAVE A REPLY ──────────────────────────────────────── -->
  <section class="bg-white px-6 py-12 border-t border-[#e0e0e0]">
    <div class="container mx-auto max-w-3xl">
      <h2 style="font-size:18px!important;font-weight:700!important;color:#1D1C1C!important;text-transform:uppercase!important;letter-spacing:0.05em!important;margin:0 0 16px 0!important;">LEAVE A REPLY</h2>
      <p class="text-[#666] text-sm mb-6">Your email address will not be published. Required fields are marked *</p>
      <form id="comment-form" class="space-y-5">
        <div>
          <label class="block text-[#1D1C1C] text-sm font-medium mb-1.5">Comment *</label>
          <textarea name="comment" required rows="6" class="w-full border-2 border-[#2EAB5A] rounded-xl px-4 py-3 text-sm text-[#444] focus:outline-none focus:ring-2 focus:ring-[#2EAB5A] focus:border-transparent resize-vertical"></textarea>
        </div>
        <div>
          <label class="block text-[#1D1C1C] text-sm font-medium mb-1.5">Name *</label>
          <input type="text" name="name" required class="w-full border-2 border-[#2EAB5A] rounded-xl px-4 py-3 text-sm text-[#444] focus:outline-none focus:ring-2 focus:ring-[#2EAB5A] focus:border-transparent" />
        </div>
        <div>
          <label class="block text-[#1D1C1C] text-sm font-medium mb-1.5">Email *</label>
          <input type="email" name="email" required class="w-full border-2 border-[#2EAB5A] rounded-xl px-4 py-3 text-sm text-[#444] focus:outline-none focus:ring-2 focus:ring-[#2EAB5A] focus:border-transparent" />
        </div>
        <div>
          <label class="block text-[#1D1C1C] text-sm font-medium mb-1.5">Website</label>
          <input type="url" name="website" class="w-full border-2 border-[#2EAB5A] rounded-xl px-4 py-3 text-sm text-[#444] focus:outline-none focus:ring-2 focus:ring-[#2EAB5A] focus:border-transparent" />
        </div>
        <div class="flex items-start gap-2">
          <input type="checkbox" name="save" id="save-info" class="mt-1 accent-[#2EAB5A]" />
          <label for="save-info" class="text-[#444] text-sm">Save my name, email, and website in this browser for the next time I comment.</label>
        </div>
        <button type="submit" class="bg-[#2EAB5A] text-white font-bold text-sm rounded-full px-8 py-3 hover:bg-[#248f4a] transition-colors">Post Comment</button>
      </form>
    </div>
  </section>

  <!-- ── RECENT POSTS ──────────────────────────────────────── -->
  <section class="bg-[#f5f5f0] py-12 lg:py-16 px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { title: 'Support Key Projects in Manipur', date: 'March 18, 2025', image: 'https://globalhopeindia.org/wp-content/uploads/2025/03/GHI-Blog-2-03.18.25.webp', url: '/blog/support-key-projects-in-manipur' },
          { title: 'Medical Camp Miracles: Healing Bodies and Souls', date: 'March 18, 2025', image: 'https://globalhopeindia.org/wp-content/uploads/2025/03/GHI-Blog-1-03.18.25.webp', url: '/blog/medical-camp-miracles-healing-bodies-and-souls' },
          { title: "Hope for India's Special Needs Community: The Mission of Raja's Home", date: 'March 4, 2025', image: 'https://globalhopeindia.org/wp-content/uploads/2025/03/GHI-04.04.25-2.webp', url: '/blog/hope-for-indias-special-needs' },
        ].map(card => (
          <a href={card.url} class="group bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden flex flex-col">
            <div class="overflow-hidden">
              <img src={card.image} alt={card.title} class="w-full h-[180px] object-cover object-bottom transition-transform duration-300 group-hover:scale-105" />
            </div>
            <div class="p-4 flex flex-col flex-1">
              <p class="blog-card-title" style="font-size:16px!important;font-weight:600!important;color:#3B9C5A!important;line-height:1.4!important;margin:0 0 8px 0!important;">{card.title}</p>
              <div class="flex items-center gap-1.5 text-[#2EAB5A] text-xs mb-3">
                <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 448 512" fill="currentColor"><path d="M12 192h424c6.6 0 12 5.4 12 12v260c0 26.5-21.5 48-48 48H48c-26.5 0-48-21.5-48-48V204c0-6.6 5.4-12 12-12zm436-44v-36c0-26.5-21.5-48-48-48h-48V12c0-6.6-5.4-12-12-12h-40c-6.6 0-12 5.4-12 12v52H160V12c0-6.6-5.4-12-12-12h-40c-6.6 0-12 5.4-12 12v52H48C21.5 64 0 85.5 0 112v36c0 6.6 5.4 12 12 12h424c6.6 0 12-5.4 12-12z"/></svg>
                <span>{card.date}</span>
              </div>
              <div class="mt-auto inline-flex items-center gap-1.5 text-[#2EAB5A] text-sm font-semibold group-hover:underline">
                Read Full Story Here
                <svg class="w-3.5 h-3.5" viewBox="0 0 448 512" fill="currentColor"><path d="M190.5 66.9l22.2-22.2c9.4-9.4 24.6-9.4 33.9 0L441 239c9.4 9.4 9.4 24.6 0 33.9L246.6 467.3c-9.4 9.4-24.6 9.4-33.9 0l-22.2-22.2c-9.5-9.5-9.3-25 .4-34.3L311.4 296H24c-13.3 0-24-10.7-24-24v-32c0-13.3 10.7-24 24-24h287.4L190.9 101.2c-9.8-9.3-10-24.8-.4-34.3z"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<script>
  const btn = document.getElementById('copy-btn');
  const label = document.getElementById('copy-label');
  if (btn && label) {
    btn.addEventListener('click', () => {
      const url = btn.getAttribute('data-url') || window.location.href;
      navigator.clipboard.writeText(url).then(() => {
        label.textContent = 'Copied!';
        setTimeout(() => { label.textContent = 'Copy link'; }, 2000);
      });
    });
  }
</script>
