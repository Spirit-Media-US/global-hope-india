---
import Layout from '../../layouts/Layout.astro';
import { sanityClient, urlFor } from '../../lib/sanity.ts';

export async function getStaticPaths() {
  try {
    const posts = await sanityClient.fetch(`*[_type == "blogPost"] { "slug": slug.current }`);
    return posts.map((p: any) => ({ params: { slug: p.slug } }));
  } catch (e) {
    // Sanity not yet configured — no blog posts to build
    return [];
  }
}

const { slug } = Astro.params;

let post: any = null;
let related: any[] = [];
try {
  post = await sanityClient.fetch(
    `*[_type == "blogPost" && slug.current == $slug][0]`,
    { slug }
  );
  if (post?.tags?.length) {
    related = await sanityClient.fetch(
      `*[_type == "blogPost" && slug.current != $slug && count((tags)[@ in $tags]) > 0] | order(publishDate desc) [0..2] {
        title, "slug": slug.current, excerpt, publishDate, "imageUrl": heroImage.asset->url, tags
      }`,
      { slug, tags: post.tags }
    );
  }
} catch (e) {
  // Sanity not yet configured
}

if (!post) return Astro.redirect('/blog');

function renderPortableText(blocks: any[]): string {
  if (!Array.isArray(blocks)) return '';
  return blocks.map((block: any) => {
    if (!block || block._type !== 'block') return '';
    const children = Array.isArray(block.children) ? block.children : [];
    const text = children.map((child: any) => {
      if (!child) return '';
      let t = child.text || '';
      const marks = Array.isArray(child.marks) ? child.marks : [];
      if (marks.includes('strong')) t = `<strong>${t}</strong>`;
      if (marks.includes('em')) t = `<em>${t}</em>`;
      const linkMark = marks.find((m: any) => m && typeof m === 'object' && m._type === 'link');
      if (linkMark?.href) t = `<a href="${linkMark.href}" class="text-[#2EAB5A] hover:underline" target="_blank" rel="noopener noreferrer">${t}</a>`;
      return t;
    }).join('');
    const style = block.style || 'normal';
    if (style === 'h2') return `<h2 class="text-2xl font-bold mt-10 mb-4">${text}</h2>`;
    if (style === 'h3') return `<h3 class="text-xl font-bold mt-8 mb-3">${text}</h3>`;
    return `<p class="text-[#444] leading-relaxed mb-5">${text}</p>`;
  }).join('');
}

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const formatDate = (d: string) => {
  const dt = new Date(d);
  return `${MONTHS[dt.getUTCMonth()]} ${dt.getUTCDate()}, ${dt.getUTCFullYear()}`;
};

const heroImage = post.heroImage
  ? urlFor(post.heroImage).width(1200).format('webp').url()
  : null;
const author = post.author || 'Global Hope India';
const tags = post.tags || [];
const bodyHtml = renderPortableText(post.body);
const publishDate = post.publishDate ? formatDate(post.publishDate) : '';
const postUrl = `https://globalhopeindia.org/blog/${slug}`;
const encodedUrl = encodeURIComponent(postUrl);
const encodedTitle = encodeURIComponent(post.title);
---

<Layout
  title={post.seoTitle || `${post.title} | GHI Magazine`}
  description={post.seoDescription || post.excerpt || 'Read this story on the Global Hope India blog.'}
  ogImage={heroImage || '/og-default.jpg'}
>
  <Fragment slot="head">
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="article" />
    <meta property="article:author" content={author} />
    <meta property="article:published_time" content={post.publishDate} />
    {tags.length > 0 && <meta property="article:section" content={tags[0]} />}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.title,
      "description": post.excerpt || post.title,
      "image": heroImage,
      "author": { "@type": "Organization", "name": "Global Hope India" },
      "publisher": { "@type": "Organization", "name": "Global Hope India", "url": "https://globalhopeindia.org" },
      "url": postUrl,
      "datePublished": post.publishDate
    })}></script>
  </Fragment>

  <!-- ── HERO IMAGE ─────────────────────────────────────────── -->
  {heroImage && (
    <div class="w-full pt-20">
      <img src={heroImage} alt={post.heroImage?.alt || post.title} class="w-full h-64 lg:h-[500px] object-cover" />
    </div>
  )}

  <!-- ── POST HEADER ───────────────────────────────────────── -->
  <section class={`bg-white px-6 ${heroImage ? 'pt-10' : 'pt-36'} pb-4`}>
    <div class="container mx-auto max-w-3xl">
      <a href="/blog" class="inline-flex items-center gap-1.5 text-sm font-semibold text-[#2EAB5A] hover:text-[#1D1C1C] transition-colors mb-6">← Back to Magazine</a>
      <h1 class="mb-4">{post.title}</h1>
      {post.excerpt && <p class="text-[#555] text-lg leading-relaxed mb-5">{post.excerpt}</p>}
      <div class="flex items-center gap-3 pb-8 text-sm text-[#888] border-b border-[#e0e0e0]">
        <span>By <span class="font-semibold text-[#1D1C1C]">{author}</span></span>
        <span>·</span>
        <span>{publishDate}</span>
      </div>
    </div>
  </section>

  <!-- ── TAGS ──────────────────────────────────────────────── -->
  {tags.length > 0 && (
    <section class="bg-white px-6 pb-6 border-b border-[#e0e0e0]">
      <div class="container mx-auto max-w-3xl flex flex-wrap gap-2">
        {tags.map((tag: string) => (
          <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="text-xs font-semibold text-[#1D1C1C] bg-[#FEC415]/20 hover:bg-[#FEC415] rounded-full px-3 py-1 transition-colors">{tag}</a>
        ))}
      </div>
    </section>
  )}

  <!-- ── CONTENT ───────────────────────────────────────────── -->
  <section class="bg-white px-6 py-12">
    <div class="container mx-auto max-w-3xl">
      <div set:html={bodyHtml} />
    </div>
  </section>

  <!-- ── SHARE BAR ─────────────────────────────────────────── -->
  <section class="bg-[#f5f5f5] px-6 py-10 border-t border-[#e0e0e0]">
    <div class="container mx-auto max-w-3xl">
      <div class="flex items-center gap-4 flex-wrap">
        <span class="text-xs font-semibold text-[#888] uppercase tracking-widest shrink-0">Share this story</span>
        <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-[#e0e0e0] bg-white px-4 py-2 text-sm font-semibold text-[#555] hover:bg-[#f5f5f5] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-[#1877F2]"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
          Facebook
        </a>
        <a href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-[#e0e0e0] bg-white px-4 py-2 text-sm font-semibold text-[#555] hover:bg-[#f5f5f5] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 300 300" fill="currentColor"><path d="M178.57 127.15 290.27 0h-26.46l-97.03 110.38L89.34 0H0l117.13 166.93L0 300h26.46l102.4-116.59L194.66 300H284L178.57 127.15zm-36.26 41.26-11.87-16.61L36.16 19.54h40.68l76.17 106.66 11.87 16.61 99.05 138.65h-40.69l-80.93-113.25z"/></svg>
          X
        </a>
        <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-[#e0e0e0] bg-white px-4 py-2 text-sm font-semibold text-[#555] hover:bg-[#f5f5f5] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-[#0A66C2]"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <button id="copy-btn" data-url={postUrl} class="inline-flex items-center gap-2 rounded-lg border border-[#e0e0e0] bg-white px-4 py-2 text-sm font-semibold text-[#555] hover:bg-[#f5f5f5] transition-colors cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          <span id="copy-label">Copy link</span>
        </button>
      </div>
    </div>
  </section>

  <!-- ── RELATED POSTS ─────────────────────────────────────── -->
  {related.length > 0 && (
    <section class="section bg-white">
      <div class="container mx-auto max-w-3xl">
        <h2 class="text-xl font-bold mb-8">More Stories</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {related.map((r: any) => (
            <a href={`/blog/${r.slug}`} class="group rounded-xl border border-[#e0e0e0] overflow-hidden hover:shadow-md transition-shadow">
              <div class="h-32 overflow-hidden bg-[#1D1C1C]">
                {r.imageUrl
                  ? <img src={`${r.imageUrl}?w=400&auto=format`} alt={r.title} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
                  : <div class="w-full h-full flex items-center justify-center text-2xl">🌏</div>
                }
              </div>
              <div class="p-4">
                <h3 class="text-sm font-bold leading-snug group-hover:text-[#2EAB5A] transition-colors">{r.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── DONATE CTA ────────────────────────────────────────── -->
  <section class="section bg-[#FEC415]">
    <div class="container mx-auto text-center">
      <h2 class="text-[#1D1C1C] mb-4">Be Part of the Next Story</h2>
      <p class="text-[#1D1C1C]/80 text-lg max-w-xl mx-auto mb-8">Your gift funds real transformation — Bibles, churches, clean water, and lives changed by the gospel.</p>
      <a href="https://givebutter.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" class="btn" style="background-color: #1D1C1C; color: #FEC415; border-color: #1D1C1C;">Donate Now</a>
    </div>
  </section>
</Layout>

<script>
  const btn = document.getElementById('copy-btn');
  const label = document.getElementById('copy-label');
  if (btn && label) {
    btn.addEventListener('click', () => {
      const url = btn.getAttribute('data-url') || window.location.href;
      navigator.clipboard.writeText(url).then(() => {
        label.textContent = 'Copied!';
        setTimeout(() => { label.textContent = 'Copy link'; }, 2000);
      });
    });
  }
</script>
