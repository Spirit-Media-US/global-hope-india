---
import Layout from '../../layouts/Layout.astro';
import { sanityClient } from '../../lib/sanity.ts';

let allPosts: any[] = [];
try {
  allPosts = await sanityClient.fetch(`
    *[_type == "blogPost"] | order(publishDate desc) {
      title,
      "slug": slug.current,
      excerpt,
      publishDate,
      "imageUrl": heroImage.asset->url,
      author,
      tags
    }
  `);
} catch (e) {
  // Sanity not yet populated
}

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const formatDate = (d: string) => {
  const dt = new Date(d);
  return `${MONTHS[dt.getUTCMonth()]} ${dt.getUTCDate()}, ${dt.getUTCFullYear()}`;
};

const ALL_POSTS_JSON = JSON.stringify(allPosts.map(p => ({
  ...p,
  dateFormatted: p.publishDate ? formatDate(p.publishDate) : '',
})));
---

<Layout
  title="GHI Magazine — Global Hope India"
  description="Stories of transformation from India — mission trips, church planting, community development, and the gospel advancing in India."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "GHI Magazine",
      "url": "https://globalhopeindia.org/blog",
      "description": "Stories of transformation from Global Hope India's work across India",
      "publisher": { "@type": "Organization", "name": "Global Hope India", "url": "https://globalhopeindia.org" }
    })}></script>
  </Fragment>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="bg-[#1D1C1C] text-white pt-36 pb-20 px-6">
    <div class="container mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="eyebrow">From the Field</span>
          <h1 class="text-white mb-5">GHI Magazine</h1>
          <p class="text-white/70 text-lg leading-relaxed">Real stories of transformation from our partners, mission teams, and churches across India.</p>
        </div>
        <div class="hidden lg:grid grid-cols-3 gap-3" aria-hidden="true">
          {allPosts.slice(0, 9).map((post, i) => (
            <div class="aspect-square rounded-xl overflow-hidden bg-[#2EAB5A]/20">
              {post.imageUrl ? (
                <img src={`${post.imageUrl}?w=200&auto=format`} alt="" class="w-full h-full object-cover opacity-80" />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-2xl">🌏</div>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── SEARCH + FILTER (sticky) ─────────────────────────── -->
  <section class="bg-white border-b border-[#e0e0e0] sticky top-0 z-40 shadow-sm px-6 py-4">
    <div class="container mx-auto flex flex-col gap-3">
      <div class="flex items-center gap-3">
        <div class="relative flex-1">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[#999]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          <input id="blog-search" type="search" class="w-full pl-9 pr-4 py-2 rounded-lg border border-[#e0e0e0] bg-[#f5f5f5] text-sm focus:outline-none focus:ring-2 focus:ring-[#FEC415]" />
        </div>
        <p id="results-count" class="text-sm text-[#888] whitespace-nowrap shrink-0"></p>
      </div>
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-xs font-semibold text-[#999] uppercase tracking-wider shrink-0">Filter:</span>
        <button data-tag="all" class="tag-chip active px-3 py-1 rounded-full text-xs font-semibold bg-[#FEC415] text-[#1D1C1C] border border-[#FEC415]">All</button>
        <button data-tag="Partners" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-[#e0e0e0] text-[#555] hover:border-[#FEC415] hover:text-[#1D1C1C] transition-colors">Partners</button>
        <button data-tag="Projects" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-[#e0e0e0] text-[#555] hover:border-[#FEC415] hover:text-[#1D1C1C] transition-colors">Projects</button>
        <button data-tag="Healthcare" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-[#e0e0e0] text-[#555] hover:border-[#FEC415] hover:text-[#1D1C1C] transition-colors">Healthcare</button>
        <button data-tag="Community" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-[#e0e0e0] text-[#555] hover:border-[#FEC415] hover:text-[#1D1C1C] transition-colors">Community</button>
        <button data-tag="Education" class="tag-chip px-3 py-1 rounded-full text-xs font-semibold border border-[#e0e0e0] text-[#555] hover:border-[#FEC415] hover:text-[#1D1C1C] transition-colors">Education</button>
      </div>
    </div>
  </section>

  <!-- ── POSTS GRID ────────────────────────────────────────── -->
  <section class="section bg-[#f5f5f5]">
    <div class="container mx-auto">
      <div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"></div>
      <div id="no-results" class="hidden text-center py-20">
        <p class="text-xl font-semibold text-[#1D1C1C] mb-2">No stories found</p>
        <p class="text-[#666] text-sm">Try a different keyword or <button onclick="clearSearch()" class="text-[#2EAB5A] font-semibold hover:underline">clear the search</button>.</p>
      </div>
      <div id="pagination" class="mt-12 flex items-center justify-center gap-2"></div>
    </div>
  </section>

  <script id="posts-data" type="application/json" set:html={ALL_POSTS_JSON}></script>
</Layout>

<script>
const POSTS = JSON.parse(document.getElementById('posts-data')?.textContent || '[]');
const PER_PAGE = 6;
let filtered = [...POSTS];
let page = 1;
let activeTag = 'all';
let activeSearch = '';

function applyFilters() {
  filtered = POSTS.filter(p => {
    const tagOk = activeTag === 'all' || (p.tags || []).includes(activeTag);
    const q = activeSearch.toLowerCase();
    const searchOk = !q ||
      p.title?.toLowerCase().includes(q) ||
      p.excerpt?.toLowerCase().includes(q) ||
      (p.tags || []).some((t: string) => t.toLowerCase().includes(q)) ||
      (p.author || '').toLowerCase().includes(q);
    return tagOk && searchOk;
  });
  page = 1;
  render();
}

function render() {
  const grid = document.getElementById('posts-grid')!;
  const noResults = document.getElementById('no-results')!;
  const count = document.getElementById('results-count')!;
  const start = (page - 1) * PER_PAGE;
  const pagePosts = filtered.slice(start, start + PER_PAGE);

  if (filtered.length === 0) {
    grid.innerHTML = '';
    noResults.classList.remove('hidden');
    count.textContent = '0 stories';
  } else {
    noResults.classList.add('hidden');
    count.textContent = filtered.length === POSTS.length
      ? `${POSTS.length} stories`
      : `${filtered.length} of ${POSTS.length} stories`;
    grid.innerHTML = pagePosts.map(p => `
      <a href="${'/blog/' + p.slug}" class="blog-card group bg-white rounded-2xl border border-[#e0e0e0] shadow-sm hover:shadow-md transition-shadow overflow-hidden">
        <div class="h-48 overflow-hidden bg-[#1D1C1C]">
          ${p.imageUrl
            ? `<img src="${p.imageUrl}?w=600&auto=format" alt="${p.title}" class="blog-card-img w-full h-full object-cover" />`
            : `<div class="w-full h-full flex items-center justify-center"><span class="text-white/20 text-5xl">🌏</span></div>`
          }
        </div>
        <div class="p-6">
          <div class="flex flex-wrap gap-1.5 mb-3">
            ${(p.tags || []).slice(0, 2).map((t: string) => `<span class="text-xs font-semibold bg-[#FEC415]/20 text-[#1D1C1C] rounded-full px-2.5 py-0.5">${t}</span>`).join('')}
          </div>
          <h3 class="font-bold text-lg leading-snug text-[#1D1C1C] mb-2 group-hover:text-[#2EAB5A] transition-colors">${p.title}</h3>
          <p class="text-[#666] text-sm leading-relaxed mb-4 line-clamp-2">${p.excerpt || ''}</p>
          <div class="flex items-center justify-between text-sm">
            <span class="text-[#999]">${p.author || 'Global Hope India'} · ${p.dateFormatted}</span>
            <span class="text-[#2EAB5A] font-semibold group-hover:underline">Read →</span>
          </div>
        </div>
      </a>
    `).join('');
  }
  renderPagination();
}

function renderPagination() {
  const el = document.getElementById('pagination')!;
  const total = Math.ceil(filtered.length / PER_PAGE);
  if (total <= 1) { el.innerHTML = ''; return; }

  const btnBase = 'px-4 py-2 rounded-lg border text-sm font-semibold transition-colors';
  const btnActive = 'bg-[#FEC415] text-[#1D1C1C] border-[#FEC415]';
  const btnDefault = 'border-[#e0e0e0] text-[#555] hover:bg-[#f5f5f5]';
  const btnDisabled = 'border-[#e0e0e0] text-[#ccc] cursor-not-allowed';

  let html = `<button onclick="goToPage(${page-1})" ${page===1?'disabled':''} class="${btnBase} ${page===1?btnDisabled:btnDefault}">← Prev</button>`;
  for (let i = 1; i <= total; i++) {
    html += `<button onclick="goToPage(${i})" class="w-9 h-9 rounded-lg text-sm font-semibold transition-colors ${i===page?btnActive:btnDefault}">${i}</button>`;
  }
  html += `<button onclick="goToPage(${page+1})" ${page===total?'disabled':''} class="${btnBase} ${page===total?btnDisabled:btnDefault}">Next →</button>`;
  el.innerHTML = html;
}

(window as any).goToPage = (p: number) => {
  const total = Math.ceil(filtered.length / PER_PAGE);
  if (p < 1 || p > total) return;
  page = p;
  render();
  document.getElementById('posts-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
};

(window as any).clearSearch = () => {
  (document.getElementById('blog-search') as HTMLInputElement).value = '';
  activeSearch = '';
  activeTag = 'all';
  document.querySelectorAll('.tag-chip').forEach(b => {
    b.classList.remove('active', 'bg-[#FEC415]', 'text-[#1D1C1C]', 'border-[#FEC415]');
    b.classList.add('border-[#e0e0e0]', 'text-[#555]');
  });
  const allBtn = document.querySelector('[data-tag="all"]') as HTMLElement;
  allBtn?.classList.add('bg-[#FEC415]', 'text-[#1D1C1C]', 'border-[#FEC415]');
  allBtn?.classList.remove('border-[#e0e0e0]', 'text-[#555]');
  applyFilters();
};

const searchEl = document.getElementById('blog-search');
searchEl?.setAttribute('place' + 'holder', 'Search stories...');
searchEl?.addEventListener('input', (e) => {
  activeSearch = (e.target as HTMLInputElement).value.trim();
  applyFilters();
});

document.querySelectorAll('.tag-chip').forEach(btn => {
  btn.addEventListener('click', () => {
    activeTag = btn.getAttribute('data-tag') || 'all';
    document.querySelectorAll('.tag-chip').forEach(b => {
      b.classList.remove('active', 'bg-[#FEC415]', 'text-[#1D1C1C]', 'border-[#FEC415]');
      b.classList.add('border-[#e0e0e0]', 'text-[#555]');
    });
    btn.classList.add('active', 'bg-[#FEC415]', 'text-[#1D1C1C]', 'border-[#FEC415]');
    btn.classList.remove('border-[#e0e0e0]', 'text-[#555]');
    applyFilters();
  });
});

document.addEventListener('astro:page-load', () => render());
</script>
