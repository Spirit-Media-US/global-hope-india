---
import '../styles/global.css';
import MailtoLink from '../components/MailtoLink.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  keywords?: string;
  ogType?: string;
}

const {
  title,
  description = 'Global Hope India is a 501(c)(3) nonprofit sending mission teams, Bibles, and resources to empower indigenous churches across India for over 25 years.',
  ogImage = 'https://cdn.sanity.io/images/r33r2z1j/production/1c1bb5eb015260dd490f6b0cd7af0c34f30928c2-2560x552.webp',
  keywords,
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://globalhopeindia.org');
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Preconnect to cross-origin asset hosts -->
    <link rel="preconnect" href="https://assets.spiritmediapublishing.com" crossorigin />
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />

    <!-- Preload critical fonts (above-fold) -->
    <link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/poppins/poppins-400.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/poppins/poppins-600.woff2" crossorigin />

    <!-- Per-page head-early slot (hero preloads) -->
    <slot name="head-early" />

    <!-- ======== Critical CSS — hand-rolled, @layer base wrapped ========
         @font-face and @keyframes stay at top level (CSS spec forbids them inside @layer).
         Everything else inside @layer base so Tailwind's @layer utilities wins the cascade.
         Docs: /home/deploy/.claude/projects/-home-deploy/memory/reference_100club_cascade_rules.md -->
    <style is:inline>
      @font-face{font-family:'Poppins';font-style:normal;font-weight:400;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/poppins/poppins-400.woff2') format('woff2')}
      @font-face{font-family:'Poppins';font-style:normal;font-weight:600;font-display:swap;src:url('https://assets.spiritmediapublishing.com/fonts/poppins/poppins-600.woff2') format('woff2')}

      @layer base {
        /* Resets */
        *,*::before,*::after{box-sizing:border-box;border:0 solid}
        html{-webkit-text-size-adjust:100%;line-height:1.875;-webkit-font-smoothing:antialiased;scroll-behavior:smooth;background-color:#FFFFFF}
        body{margin:0;font-family:'Poppins',system-ui,sans-serif;color:#1D1C1C;background-color:#FFFFFF;line-height:1.875}
        img,picture,svg,video,canvas{display:block;max-width:100%;height:auto}
        h1,h2,h3,h4,h5,h6{margin:0;font-family:'Poppins',system-ui,sans-serif;font-weight:700;line-height:1.15;color:#1D1C1C;overflow-wrap:break-word}
        h1{font-size:clamp(2.2rem,5vw,4.375rem)}
        h2{font-size:clamp(1.75rem,3.5vw,3.125rem)}
        h3{font-size:clamp(1.25rem,2.5vw,1.75rem)}
        p{margin:0 0 1rem 0;overflow-wrap:break-word}
        a{color:inherit;text-decoration:none}
        button{font:inherit;color:inherit;background:transparent;cursor:pointer;padding:0;border:0}

        /* Custom component classes — hex literals (Lighthouse contrast audit can't resolve var()) */
        .container{max-width:1200px;margin-left:auto;margin-right:auto}
        .section{padding:5rem 1.5rem}
        .eyebrow{font-size:.8rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:#1D1C1C;display:block;margin-bottom:.5rem}

        /* Tailwind utility copies used above the fold */
        .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border-width:0}
        .focus\:not-sr-only:focus{position:static;width:auto;height:auto;padding:0;margin:0;overflow:visible;clip:auto;white-space:normal}
        .focus\:fixed:focus{position:fixed}
        .focus\:top-4:focus{top:1rem}
        .focus\:left-4:focus{left:1rem}
        .focus\:z-\[100\]:focus{z-index:100}
        .focus\:bg-white:focus{background-color:#fff}
        .focus\:text-\[\#1D1C1C\]:focus{color:#1D1C1C}
        .focus\:px-4:focus{padding-inline:1rem}
        .focus\:py-2:focus{padding-block:.5rem}
        .focus\:rounded-lg:focus{border-radius:.5rem}
        .focus\:shadow-lg:focus{box-shadow:0 10px 15px -3px rgba(0,0,0,.1),0 4px 6px -4px rgba(0,0,0,.1)}
        .focus\:font-semibold:focus{font-weight:600}

        .fixed{position:fixed}.absolute{position:absolute}.relative{position:relative}
        .top-0{top:0}.left-0{left:0}.right-0{right:0}.inset-0{inset:0}
        .z-10{z-index:10}.z-50{z-index:50}
        .flex{display:flex}.inline-flex{display:inline-flex}.inline-block{display:inline-block}.grid{display:grid}.block{display:block}.hidden{display:none}
        .grid-cols-1{grid-template-columns:repeat(1,minmax(0,1fr))}
        .flex-col{flex-direction:column}
        .items-center{align-items:center}.items-start{align-items:flex-start}
        .justify-center{justify-content:center}.justify-between{justify-content:space-between}
        .gap-1{gap:.25rem}.gap-2{gap:.5rem}.gap-4{gap:1rem}.gap-8{gap:2rem}
        .mx-auto{margin-inline:auto}.mt-3{margin-top:.75rem}
        .px-6{padding-inline:1.5rem}.px-8{padding-inline:2rem}.py-2{padding-block:.5rem}.py-3{padding-block:.75rem}.py-2\.5{padding-block:.625rem}.p-2{padding:.5rem}
        .w-7{width:1.75rem}.h-7{height:1.75rem}.w-auto{width:auto}.h-12{height:3rem}.h-\[68px\]{height:68px}
        .w-full{width:100%}.h-full{height:100%}.min-h-screen{min-height:100vh}
        .shrink-0{flex-shrink:0}
        .overflow-hidden{overflow:hidden}
        .object-cover{object-fit:cover}.object-contain{object-fit:contain}
        .text-center{text-align:center}
        .text-base{font-size:1rem}.text-sm{font-size:.875rem}.text-xl{font-size:1.25rem}.text-\[15px\]{font-size:15px}
        .font-medium{font-weight:500}.font-semibold{font-weight:600}.font-bold{font-weight:700}
        .bg-white{background-color:#fff}
        .bg-\[\#06038D\]{background-color:#06038D}
        .bg-\[\#1D1C1C\]{background-color:#1D1C1C}
        .bg-\[\#F8F5EF\]{background-color:#F8F5EF}
        .bg-\[\#F8C8DC\]{background-color:#F8C8DC}
        .bg-black\/40{background-color:rgba(0,0,0,.4)}
        .text-white{color:#fff}
        .text-\[\#1D1C1C\]{color:#1D1C1C}
        .text-\[\#1d803f\]{color:#1d803f}
        .border-t{border-top-width:1px}.border-gray-100{border-color:#f3f4f6}
        .rounded{border-radius:.25rem}.rounded-full{border-radius:9999px}
        .transition-colors{transition:color .15s, background-color .15s, border-color .15s}
        .duration-300{transition-duration:.3s}
        .max-w-4xl{max-width:56rem}.max-w-5xl{max-width:64rem}
        .-mt-40{margin-top:-10rem}
        .pt-10{padding-top:2.5rem}.pb-6{padding-bottom:1.5rem}
        .px-8{padding-inline:2rem}
        .leading-relaxed{line-height:1.625}
        .mb-0{margin-bottom:0}
        .py-5{padding-block:1.25rem}
        .opacity-0{opacity:0}.opacity-100{opacity:1}
        .duration-1000{transition-duration:1s}
        .transition-opacity{transition-property:opacity}

        @media(min-width:768px){
          .md\:text-base{font-size:1rem}
          .md\:-mt-32{margin-top:-8rem}
        }
        @media(min-width:1024px){
          .lg\:hidden{display:none}
          .lg\:flex{display:flex}
          .lg\:-mt-36{margin-top:-9rem}
          .lg\:pt-14{padding-top:3.5rem}
          .lg\:px-16{padding-inline:4rem}
        }
      }
    </style>

    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Global Hope India" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Per-page head slot (JSON-LD, extra meta) -->
    <slot name="head" />

    <!-- Google Analytics (GA4) — deferred until first user interaction or 8s fallback -->
    <script is:inline>
      (function() {
        let gaLoaded = false;
        function loadGA() {
          if (gaLoaded) return;
          gaLoaded = true;
          const s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-W3R21TNHTX';
          document.head.appendChild(s);
          window.dataLayer = window.dataLayer || [];
          function gtag(){ window.dataLayer.push(arguments); }
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', 'G-W3R21TNHTX');
        }
        var gaEvents=['scroll','mousemove','touchstart','keydown','click'];
        function gaTrigger(){gaEvents.forEach(function(e){window.removeEventListener(e,gaTrigger);});loadGA();}
        gaEvents.forEach(function(e){window.addEventListener(e,gaTrigger,{passive:true,once:true});});
        setTimeout(function(){if(!gaLoaded)loadGA();},8000);
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <!-- ── Navbar ─────────────────────────────────────────── -->
    <header id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-white transition-colors duration-300">
      <div class="container mx-auto px-6 flex items-center justify-between h-[68px]">
        <!-- Logo -->
        <a href="/" class="shrink-0">
          <img
            src="https://cdn.sanity.io/images/r33r2z1j/production/1c1bb5eb015260dd490f6b0cd7af0c34f30928c2-2560x552.webp?w=220&fm=webp&q=85"
            srcset="https://cdn.sanity.io/images/r33r2z1j/production/1c1bb5eb015260dd490f6b0cd7af0c34f30928c2-2560x552.webp?w=220&fm=webp&q=85 1x, https://cdn.sanity.io/images/r33r2z1j/production/1c1bb5eb015260dd490f6b0cd7af0c34f30928c2-2560x552.webp?w=440&fm=webp&q=85 2x"
            alt="Global Hope India"
            width="220"
            height="47"
            decoding="async"
            class="h-12 w-auto object-contain"
          />
        </a>

        <!-- Desktop nav -->
        <nav class="hidden lg:flex items-center gap-8">
          {[
            { href: '/', label: 'Home' },
            { href: '/about', label: 'About' },
            { href: '/projects', label: 'Projects' },
            { href: '/get-involved', label: 'Get Involved' },
            { href: '/blog', label: 'Blog' },
          ].map(link => (
            <a
              href={link.href}
              class={`nav-link font-semibold text-base transition-colors px-3 ${
                currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                  ? 'text-[#1d803f]'
                  : 'text-[#1D1C1C] hover:text-[#1d803f]'
              }`}
            >
              {link.label}
            </a>
          ))}
          <a href="https://givebutter.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" class="bg-[#06038D] hover:bg-[#1D1C1C] text-white text-[15px] font-medium py-3 px-8 rounded transition-colors">Give to India</a>
        </nav>

        <!-- Mobile hamburger -->
        <button
          id="menu-toggle"
          class="lg:hidden text-[#1D1C1C] p-2 focus:outline-none"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Mobile donate bar (below logo row, matching original site) -->
      <div class="lg:hidden flex justify-center py-2 border-t border-gray-100">
        <a href="https://givebutter.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" class="bg-[#06038D] hover:bg-[#1D1C1C] text-white text-sm font-medium py-2.5 px-8 rounded-full transition-colors">Give to India</a>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-200 px-6 py-4">
        <nav class="flex flex-col gap-1">
          {[
            { href: '/', label: 'Home' },
            { href: '/about', label: 'About' },
            { href: '/projects', label: 'Projects' },
            { href: '/get-involved', label: 'Get Involved' },
            { href: '/blog', label: 'Blog' },
          ].map(link => (
            <a
              href={link.href}
              class={`font-semibold py-3 border-b border-gray-100 transition-colors ${
                currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                  ? 'text-[#1d803f]'
                  : 'text-[#1D1C1C] hover:text-[#1d803f]'
              }`}
            >
              {link.label}
            </a>
          ))}
          <a href="https://givebutter.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" class="bg-[#06038D] hover:bg-[#1D1C1C] text-white font-medium mt-3 text-center py-3 rounded transition-colors">Give to India</a>
        </nav>
      </div>
    </header>

    <!-- ── Page content ───────────────────────────────────── -->
    <main id="main-content">
      <slot />
    </main>

    <!-- ── Footer ─────────────────────────────────────────── -->
    <footer class="relative text-[#1D1C1C]">
      <!-- Cream background with faded crowd photo overlay -->
      <div class="absolute inset-0 bg-[#F8F5EF]"></div>
      <div class="absolute inset-0 opacity-[0.07]" style="background-image: url('https://cdn.sanity.io/images/r33r2z1j/production/c1a49b5d5cd211dcfec6e88222c0674f6d76463c-1640x924.webp'); background-size: cover; background-position: center;"></div>

      <!-- Legal banner -->
      <div class="relative z-10 py-4 px-6 border-b border-[#d5cfc5]">
        <p class="text-[#555] text-xs text-center max-w-5xl mx-auto">Global Hope India is a federally recognized 501(c)3 nonprofit organization located in Raleigh, North Carolina. All gifts are tax-deductible.</p>
      </div>

      <!-- Main footer content -->
      <div class="relative z-10 container mx-auto px-6 py-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10 items-start">

          <!-- Column 1: Logo + Contact -->
          <div class="text-center md:text-left">
            <div class="mb-5 flex justify-center md:justify-start">
              <img
                src="https://cdn.sanity.io/images/r33r2z1j/production/1c1bb5eb015260dd490f6b0cd7af0c34f30928c2-2560x552.webp"
                alt="Global Hope India"
                width="250"
                height="54"
                loading="lazy"
                class="w-[220px] lg:w-[250px] h-auto object-contain"
              />
            </div>
            <ul class="space-y-2.5 text-sm text-[#555]">
              <li class="flex items-start gap-2.5 justify-center md:justify-start">
                <svg class="w-4 h-4 text-[#1d803f] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 0 1 0-5 2.5 2.5 0 0 1 0 5z"/></svg>
                <span>PO Box 3251<br/>Cary, NC 27519</span>
              </li>
              <li class="flex items-start gap-2.5 justify-center md:justify-start">
                <svg class="w-4 h-4 text-[#1d803f] mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                <span class="inline-flex flex-col gap-1">
                  <a href="tel:9194382444" class="inline-block py-2 hover:text-[#1d803f] transition-colors">Office: 919-438-2444</a>
                  <a href="tel:18555382444" class="inline-block py-2 hover:text-[#1d803f] transition-colors">Toll Free: 1-855-538-2444</a>
                </span>
              </li>
            </ul>
          </div>

          <!-- Column 2: Donate + Social -->
          <div class="flex flex-col items-center gap-5">
            <a
              href="https://givebutter.com/GlobalHopeIndia"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block bg-[#06038D] hover:bg-[#1D1C1C] text-white font-semibold text-lg px-10 py-4 rounded-full transition-colors shadow-md"
            >Donate Now</a>
            <!-- Social icons in green squares -->
            <div class="flex gap-2">
              <a href="https://www.facebook.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-9 h-9 bg-[#2EAB5A] hover:bg-[#259a4e] rounded flex items-center justify-center transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
              </a>
              <a href="https://twitter.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" aria-label="Twitter/X" class="w-9 h-9 bg-[#2EAB5A] hover:bg-[#259a4e] rounded flex items-center justify-center transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" viewBox="0 0 300 300" fill="currentColor"><path d="M178.57 127.15 290.27 0h-26.46l-97.03 110.38L89.34 0H0l117.13 166.93L0 300h26.46l102.4-116.59L194.66 300H284L178.57 127.15zm-36.26 41.26-11.87-16.61L36.16 19.54h40.68l76.17 106.66 11.87 16.61 99.05 138.65h-40.69l-80.93-113.25z"/></svg>
              </a>
              <a href="https://www.youtube.com/@GlobalHopeIndia" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="w-9 h-9 bg-[#2EAB5A] hover:bg-[#259a4e] rounded flex items-center justify-center transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </a>
              <a href="https://www.instagram.com/globalhopeindia" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-9 h-9 bg-[#2EAB5A] hover:bg-[#259a4e] rounded flex items-center justify-center transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
