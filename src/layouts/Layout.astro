---
import '../styles/global.css';
import MailtoLink from '../components/MailtoLink.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Global Hope India empowers the church in India to make Christ known. Join us through prayer, giving, and going.',
  ogImage = 'https://cdn.sanity.io/images/r33r2z1j/production/1c1bb5eb015260dd490f6b0cd7af0c34f30928c2-2560x552.webp',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://globalhopeindia.org');
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Global Hope India" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Poppins font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-W3R21TNHTX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-W3R21TNHTX');
    </script>

    <slot name="head" />
  </head>
  <body>
    <!-- ── Navbar ─────────────────────────────────────────── -->
    <header id="navbar" class="fixed top-0 left-0 right-0 z-50 bg-white shadow-sm">
      <div class="container mx-auto px-6 flex items-center justify-between h-24">
        <!-- Logo -->
        <a href="/" class="shrink-0">
          <img
            src="https://cdn.sanity.io/images/r33r2z1j/production/1c1bb5eb015260dd490f6b0cd7af0c34f30928c2-2560x552.webp"
            alt="Global Hope India"
            width="220"
            height="47"
            class="h-12 w-auto object-contain"
          />
        </a>

        <!-- Desktop nav -->
        <nav class="hidden lg:flex items-center gap-8">
          {[
            { href: '/', label: 'Home' },
            { href: '/about', label: 'About' },
            { href: '/projects', label: 'Projects' },
            { href: '/get-involved', label: 'Get Involved' },
            { href: '/impact', label: 'Impact' },
            { href: '/blog', label: 'Blog' },
          ].map(link => (
            <a
              href={link.href}
              class={`nav-link font-medium text-sm transition-colors ${
                currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                  ? 'text-[#2EAB5A] underline underline-offset-4 decoration-2'
                  : 'text-[#1D1C1C] hover:text-[#2EAB5A]'
              }`}
            >
              {link.label}
            </a>
          ))}
          <a href="https://givebutter.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" class="bg-[#4A55A2] hover:bg-[#3b4589] text-white text-sm font-semibold py-2 px-6 rounded-full transition-colors">Donate</a>
        </nav>

        <!-- Mobile hamburger -->
        <button
          id="menu-toggle"
          class="lg:hidden text-[#1D1C1C] p-2 focus:outline-none"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-200 px-6 py-4">
        <nav class="flex flex-col gap-1">
          {[
            { href: '/', label: 'Home' },
            { href: '/about', label: 'About' },
            { href: '/projects', label: 'Projects' },
            { href: '/get-involved', label: 'Get Involved' },
            { href: '/impact', label: 'Impact' },
            { href: '/blog', label: 'Blog' },
          ].map(link => (
            <a
              href={link.href}
              class={`font-medium py-3 border-b border-gray-100 transition-colors ${
                currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                  ? 'text-[#2EAB5A]'
                  : 'text-[#1D1C1C] hover:text-[#2EAB5A]'
              }`}
            >
              {link.label}
            </a>
          ))}
          <a href="https://givebutter.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" class="bg-[#4A55A2] hover:bg-[#3b4589] text-white font-semibold mt-3 text-center py-3 rounded-full transition-colors">Donate Now</a>
        </nav>
      </div>
    </header>

    <!-- ── Page content ───────────────────────────────────── -->
    <main>
      <slot />
    </main>

    <!-- ── Footer ─────────────────────────────────────────── -->
    <footer class="bg-[#1D1C1C] text-white">
      <div class="container mx-auto px-6 py-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <!-- Brand -->
          <div>
            <div class="flex items-center gap-3 mb-4">
              <img
                src="https://cdn.sanity.io/images/r33r2z1j/production/1c1bb5eb015260dd490f6b0cd7af0c34f30928c2-2560x552.webp"
                alt="Global Hope India"
                width="56"
                height="56"
                class="w-14 h-14 object-contain"
              />
              <span class="font-bold text-lg leading-tight">Global Hope<br/>India</span>
            </div>
            <p class="text-white/70 text-sm leading-relaxed">Sharing Jesus by Sending People, Funding, and Resources to India.</p>
            <!-- Social icons -->
            <div class="flex gap-4 mt-5">
              <a href="https://www.facebook.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-white/60 hover:text-[#FEC415] transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
              </a>
              <a href="https://twitter.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" aria-label="Twitter/X" class="text-white/60 hover:text-[#FEC415] transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 300 300" fill="currentColor"><path d="M178.57 127.15 290.27 0h-26.46l-97.03 110.38L89.34 0H0l117.13 166.93L0 300h26.46l102.4-116.59L194.66 300H284L178.57 127.15zm-36.26 41.26-11.87-16.61L36.16 19.54h40.68l76.17 106.66 11.87 16.61 99.05 138.65h-40.69l-80.93-113.25z"/></svg>
              </a>
              <a href="https://www.youtube.com/@GlobalHopeIndia" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="text-white/60 hover:text-[#FEC415] transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </a>
              <a href="https://www.instagram.com/globalhopeindia" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-white/60 hover:text-[#FEC415] transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
              </a>
              <a href="https://vimeo.com/globalhopeindia" target="_blank" rel="noopener noreferrer" aria-label="Vimeo" class="text-white/60 hover:text-[#FEC415] transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.977 6.416c-.105 2.338-1.739 5.543-4.894 9.609-3.268 4.247-6.026 6.37-8.29 6.37-1.409 0-2.578-1.294-3.553-3.881L5.322 11.4C4.603 8.816 3.834 7.522 3.01 7.522c-.179 0-.806.378-1.881 1.132L0 7.197c1.185-1.044 2.351-2.084 3.501-3.128C5.08 2.701 6.266 1.984 7.055 1.91c1.867-.18 3.016 1.1 3.447 3.838.465 2.953.787 4.789.968 5.441.537 2.45 1.138 3.659 1.809 3.659.512 0 1.284-.808 2.316-2.426 1.017-1.624 1.561-2.853 1.615-3.691.145-1.401-.396-2.098-1.615-2.098-.574 0-1.162.138-1.779.397 1.179-3.858 3.45-5.757 6.823-5.693 2.479.048 3.645 1.683 3.518 4.913l-.18-.334z"/></svg>
              </a>
            </div>
          </div>

          <!-- Quick links -->
          <div>
            <h4 class="font-bold text-base mb-5 text-[#FEC415]">Quick Links</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/" class="text-white/70 hover:text-white transition-colors">Home</a></li>
              <li><a href="/about" class="text-white/70 hover:text-white transition-colors">About GHI</a></li>
              <li><a href="/projects" class="text-white/70 hover:text-white transition-colors">Projects</a></li>
              <li><a href="/get-involved" class="text-white/70 hover:text-white transition-colors">Get Involved</a></li>
              <li><a href="/impact" class="text-white/70 hover:text-white transition-colors">Impact</a></li>
              <li><a href="/blog" class="text-white/70 hover:text-white transition-colors">Blog</a></li>
              <li><a href="https://givebutter.com/GlobalHopeIndia" target="_blank" rel="noopener noreferrer" class="text-[#FEC415] font-semibold hover:text-white transition-colors">Donate Now</a></li>
              <li><a href="/privacy-policy" class="text-white/70 hover:text-white transition-colors">Privacy Policy</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h4 class="font-bold text-base mb-5 text-[#FEC415]">Contact Us</h4>
            <ul class="space-y-3 text-sm text-white/70">
              <li class="flex gap-2">
                <span>📍</span>
                <span>PO Box 3251<br/>Cary, NC 27519</span>
              </li>
              <li class="flex gap-2">
                <span>📞</span>
                <span><a href="tel:9194382444" class="hover:text-white transition-colors">919-438-2444</a><br/>
                <span class="text-white/50">Toll Free:</span> <a href="tel:18555382444" class="hover:text-white transition-colors">1-855-538-2444</a></span>
              </li>
              <li class="flex gap-2">
                <span>✉️</span>
                <MailtoLink email="info@globalhopeindia.org" class="hover:text-white transition-colors">info@globalhopeindia.org</MailtoLink>
              </li>
            </ul>
          </div>
        </div>

        <!-- Trust badges row -->
        <div class="border-t border-white/10 mt-12 pt-8">
          <p class="text-white/50 text-xs text-center mb-6">Global Hope India is a federally recognized 501(c)3 nonprofit. All gifts are tax-deductible.</p>
          <div class="flex flex-wrap items-center justify-center gap-6 mb-8">
            <img src="https://cdn.sanity.io/images/r33r2z1j/production/767b76c41ccc43b3c07f07c94435a4dcc3ad13b3-500x500.svg" alt="GuideStar" class="h-12 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="https://cdn.sanity.io/images/r33r2z1j/production/07b08d8f4d9321bb85fa7814ef0d65a742b3463e-500x500.png" alt="Charity Navigator" class="h-12 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="https://cdn.sanity.io/images/r33r2z1j/production/f256d3af6f9dbfbc282103b8fb3f7037a98d64db-500x500.png" alt="Better Business Bureau" class="h-12 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="https://cdn.sanity.io/images/r33r2z1j/production/7de612782e20fce24ac52474b16b6bf4e011c126-500x500.png" alt="Cary Chamber of Commerce" class="h-12 opacity-70 hover:opacity-100 transition-opacity" />
            <img src="https://cdn.sanity.io/images/r33r2z1j/production/cd3ad9882d7c42491f7d98a8df1b71e6868b6e68-135x135.svg" alt="Chamber Affiliation" class="h-12 opacity-70 hover:opacity-100 transition-opacity" />
          </div>
          <p class="text-white/40 text-xs text-center">© {new Date().getFullYear()} Copyright by Spirit Media</p>
        </div>
      </div>
    </footer>

    <!-- ── Navbar scroll script ────────────────────────────── -->
    <script>
      const navbar = document.getElementById('navbar');
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const iconMenu = document.getElementById('icon-menu');
      const iconClose = document.getElementById('icon-close');

      // Add shadow on scroll
      function handleScroll() {
        if (window.scrollY > 50) {
          navbar?.classList.add('shadow-md');
          navbar?.classList.remove('shadow-sm');
        } else {
          navbar?.classList.remove('shadow-md');
          navbar?.classList.add('shadow-sm');
        }
      }
      window.addEventListener('scroll', handleScroll, { passive: true });
      handleScroll();

      // Mobile menu toggle
      menuToggle?.addEventListener('click', () => {
        const isOpen = !mobileMenu?.classList.contains('hidden');
        mobileMenu?.classList.toggle('hidden', isOpen);
        iconMenu?.classList.toggle('hidden', !isOpen);
        iconClose?.classList.toggle('hidden', isOpen);
        menuToggle.setAttribute('aria-expanded', String(!isOpen));
      });

      // Re-run on Astro client-side nav
      document.addEventListener('astro:page-load', () => { handleScroll(); });
    </script>
  </body>
</html>
